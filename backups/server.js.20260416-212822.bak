import http from "http";
import express from "express";
import { WebSocketServer } from "ws";
import sqlite3 from "sqlite3";
import { open } from "sqlite";

const app = express();
app.use(express.json());
app.use(express.static("public_dashboard"));

const PORT = process.env.PORT || 3000;

const globalEvents = [];
const trendStore = new Map();
const userHistory = new Map();
const alertCooldown = new Map();

let wss;
let db;

// ====================
// DB init
// ====================
async function initDb() {
  db = await open({
    filename: "./signaldesk.db",
    driver: sqlite3.Database
  });

  await db.exec(`
    CREATE TABLE IF NOT EXISTS incidents (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      type TEXT,
      user TEXT,
      amount REAL,
      ip TEXT,
      risk INTEGER,
      timestamp INTEGER,
      riskScore INTEGER,
      action TEXT,
      severity TEXT,
      correlation TEXT,
      trend TEXT,
      trendAnomaly TEXT
    );

    CREATE TABLE IF NOT EXISTS actions (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      action TEXT,
      reason TEXT,
      priority TEXT,
      source TEXT,
      time TEXT
    );

    CREATE TABLE IF NOT EXISTS decisions (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      incidentId INTEGER,
      user TEXT,
      recommendedAction TEXT,
      actualAction TEXT,
      status TEXT,
      riskScore INTEGER,
      severity TEXT,
      reasonCodes TEXT,
      executionMode TEXT,
      assignedTo TEXT,
      note TEXT,
      createdAt INTEGER,
      updatedAt INTEGER,
      expiresAt INTEGER
    );

    CREATE TABLE IF NOT EXISTS decision_timeline (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      decisionId INTEGER,
      actorType TEXT,
      actorId TEXT,
      action TEXT,
      fromStatus TEXT,
      toStatus TEXT,
      note TEXT,
      timestamp INTEGER
    );

    CREATE TABLE IF NOT EXISTS enforcements (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      decisionId INTEGER,
      action TEXT,
      targetType TEXT,
      targetId TEXT,
      status TEXT,
      mode TEXT,
      startedAt INTEGER,
      endedAt INTEGER
    );
  `);
}

// ====================
// Helpers
// ====================
function broadcast(type, payload) {
  if (!wss) return;
  const message = JSON.stringify({ type, payload });

  wss.clients.forEach((client) => {
    if (client.readyState === 1) {
      client.send(message);
    }
  });
}

function parseMaybeJson(value) {
  if (!value) return null;
  try {
    return JSON.parse(value);
  } catch {
    return null;
  }
}

function formatDecision(row) {
  if (!row) return null;
  return {
    ...row,
    reasonCodes: parseMaybeJson(row.reasonCodes) || []
  };
}

async function getRecentIncidents(limit = 20) {
  const rows = await db.all(
    `SELECT * FROM incidents ORDER BY id DESC LIMIT ?`,
    [limit]
  );

  return rows.map((row) => ({
    ...row,
    correlation: parseMaybeJson(row.correlation),
    trend: parseMaybeJson(row.trend),
    trendAnomaly: parseMaybeJson(row.trendAnomaly)
  }));
}

async function getRecentActions(limit = 20) {
  return db.all(
    `SELECT * FROM actions ORDER BY id DESC LIMIT ?`,
    [limit]
  );
}

async function getRecentDecisions(limit = 20, filters = {}) {
  const clauses = [];
  const params = [];

  if (filters.status) {
    clauses.push(`status = ?`);
    params.push(filters.status);
  }

  if (filters.action) {
    clauses.push(`recommendedAction = ?`);
    params.push(filters.action);
  }

  if (filters.assignedTo) {
    clauses.push(`assignedTo = ?`);
    params.push(filters.assignedTo);
  }

  const where = clauses.length ? `WHERE ${clauses.join(" AND ")}` : "";
  const rows = await db.all(
    `SELECT * FROM decisions ${where} ORDER BY id DESC LIMIT ?`,
    [...params, limit]
  );

  return rows.map(formatDecision);
}

async function getDecisionById(id) {
  const row = await db.get(`SELECT * FROM decisions WHERE id = ?`, [id]);
  return formatDecision(row);
}

async function getTimelineByDecisionId(decisionId) {
  return db.all(
    `SELECT * FROM decision_timeline WHERE decisionId = ? ORDER BY id ASC`,
    [decisionId]
  );
}

async function getEnforcementByDecisionId(decisionId) {
  return db.get(
    `SELECT * FROM enforcements WHERE decisionId = ? ORDER BY id DESC LIMIT 1`,
    [decisionId]
  );
}

async function saveIncident(incident) {
  const result = await db.run(
    `INSERT INTO incidents
    (type, user, amount, ip, risk, timestamp, riskScore, action, severity, correlation, trend, trendAnomaly)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
    [
      incident.type || null,
      incident.user || null,
      incident.amount || null,
      incident.ip || null,
      incident.risk || 0,
      incident.timestamp,
      incident.riskScore,
      incident.action,
      incident.severity,
      incident.correlation ? JSON.stringify(incident.correlation) : null,
      incident.trend ? JSON.stringify(incident.trend) : null,
      incident.trendAnomaly ? JSON.stringify(incident.trendAnomaly) : null
    ]
  );

  return result.lastID;
}

async function pushAction(action, reason, priority = "normal", source = "SignalDesk Engine") {
  const newAction = {
    action,
    reason,
    priority,
    source,
    time: new Date().toLocaleTimeString("sv-SE")
  };

  const result = await db.run(
    `INSERT INTO actions (action, reason, priority, source, time)
     VALUES (?, ?, ?, ?, ?)`,
    [newAction.action, newAction.reason, newAction.priority, newAction.source, newAction.time]
  );

  newAction.id = result.lastID;
  broadcast("action", newAction);
  return newAction;
}

function severityFromRisk(riskScore) {
  if (riskScore >= 85) return "critical";
  if (riskScore >= 65) return "high";
  if (riskScore >= 45) return "medium";
  return "low";
}

function buildReasonCodes(event, riskScore, correlation, trendAnomaly) {
  const codes = [];

  if (riskScore >= 85) codes.push("risk_over_85");
  else if (riskScore >= 65) codes.push("risk_over_65");
  else if (riskScore >= 45) codes.push("risk_over_45");
  else codes.push("low_risk");

  if (event.ip === "unknown") codes.push("unknown_ip");
  if ((event.attempts || 0) > 3) codes.push("login_attempt_spike");
  if ((event.amount || 0) > 5000) codes.push("high_amount");

  const userKey = event.user || "unknown";
  const history = userHistory.get(userKey) || [];
  const recent = history.filter((t) => Date.now() - t < 60000);
  if (recent.length > 5) codes.push("velocity_spike");

  if (trendAnomaly?.level === "high") codes.push("trend_anomaly_high");
  if (trendAnomaly?.level === "medium") codes.push("trend_anomaly_medium");
  if (correlation?.level === "critical") codes.push("correlation_critical");

  return [...new Set(codes)];
}

function decisionStatusFromAction(action) {
  if (action === "log") return "resolved";
  return "pending_review";
}

async function addTimelineEntry({
  decisionId,
  actorType,
  actorId,
  action,
  fromStatus = null,
  toStatus = null,
  note = ""
}) {
  const timestamp = Date.now();

  const result = await db.run(
    `INSERT INTO decision_timeline
    (decisionId, actorType, actorId, action, fromStatus, toStatus, note, timestamp)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,
    [decisionId, actorType, actorId, action, fromStatus, toStatus, note, timestamp]
  );

  const entry = {
    id: result.lastID,
    decisionId,
    actorType,
    actorId,
    action,
    fromStatus,
    toStatus,
    note,
    timestamp
  };

  broadcast("decision_timeline", entry);
  return entry;
}

async function createDecisionFromIncident(incidentId, incident) {
  const reasonCodes = buildReasonCodes(
    incident,
    incident.riskScore,
    incident.correlation,
    incident.trendAnomaly
  );

  const status = decisionStatusFromAction(incident.action);
  const now = Date.now();

  const result = await db.run(
    `INSERT INTO decisions
    (incidentId, user, recommendedAction, actualAction, status, riskScore, severity, reasonCodes, executionMode, assignedTo, note, createdAt, updatedAt, expiresAt)
    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
    [
      incidentId,
      incident.user || "unknown",
      incident.action,
      null,
      status,
      incident.riskScore,
      incident.severity,
      JSON.stringify(reasonCodes),
      "simulated",
      null,
      "",
      now,
      now,
      now + 30 * 60 * 1000
    ]
  );

  const decision = await getDecisionById(result.lastID);

  await addTimelineEntry({
    decisionId: decision.id,
    actorType: "system",
    actorId: "system",
    action: "decision_created",
    fromStatus: null,
    toStatus: status,
    note: `Recommended action: ${decision.recommendedAction}`
  });

  broadcast("decision", decision);
  return decision;
}

async function updateDecision(decisionId, fields) {
  const current = await getDecisionById(decisionId);
  if (!current) return null;

  const next = {
    ...current,
    ...fields,
    reasonCodes:
      fields.reasonCodes !== undefined ? fields.reasonCodes : current.reasonCodes,
    updatedAt: Date.now()
  };

  await db.run(
    `UPDATE decisions
     SET incidentId = ?, user = ?, recommendedAction = ?, actualAction = ?, status = ?, riskScore = ?, severity = ?, reasonCodes = ?, executionMode = ?, assignedTo = ?, note = ?, createdAt = ?, updatedAt = ?, expiresAt = ?
     WHERE id = ?`,
    [
      next.incidentId,
      next.user,
      next.recommendedAction,
      next.actualAction,
      next.status,
      next.riskScore,
      next.severity,
      JSON.stringify(next.reasonCodes || []),
      next.executionMode,
      next.assignedTo,
      next.note,
      next.createdAt,
      next.updatedAt,
      next.expiresAt,
      decisionId
    ]
  );

  const updated = await getDecisionById(decisionId);
  broadcast("decision_update", updated);
  return updated;
}

async function approveDecision(decisionId, operatorId = "operator", note = "") {
  const decision = await getDecisionById(decisionId);
  if (!decision) return { error: "Decision not found", status: 404 };
  if (decision.status !== "pending_review") {
    return { error: "Decision is not pending review", status: 400 };
  }

  const updated = await updateDecision(decisionId, {
    status: "approved",
    note: note || decision.note
  });

  await addTimelineEntry({
    decisionId,
    actorType: "operator",
    actorId: operatorId,
    action: "approved",
    fromStatus: decision.status,
    toStatus: "approved",
    note
  });

  return { ok: true, decision: updated };
}

async function rejectDecision(decisionId, operatorId = "operator", note = "") {
  const decision = await getDecisionById(decisionId);
  if (!decision) return { error: "Decision not found", status: 404 };
  if (!["pending_review", "approved"].includes(decision.status)) {
    return { error: "Decision cannot be rejected", status: 400 };
  }

  const updated = await updateDecision(decisionId, {
    status: "rejected",
    actualAction: "rejected",
    note: note || decision.note
  });

  await addTimelineEntry({
    decisionId,
    actorType: "operator",
    actorId: operatorId,
    action: "rejected",
    fromStatus: decision.status,
    toStatus: "rejected",
    note
  });

  return { ok: true, decision: updated };
}

async function executeDecision(decisionId, operatorId = "operator", note = "") {
  const decision = await getDecisionById(decisionId);
  if (!decision) return { error: "Decision not found", status: 404 };
  if (!["approved", "pending_review"].includes(decision.status)) {
    return { error: "Decision cannot be executed", status: 400 };
  }

  const updated = await updateDecision(decisionId, {
    status: "executed",
    actualAction: decision.recommendedAction
  });

  const existing = await getEnforcementByDecisionId(decisionId);

  let enforcement;
  if (existing) {
    await db.run(
      `UPDATE enforcements
       SET action = ?, targetType = ?, targetId = ?, status = ?, mode = ?, startedAt = ?, endedAt = ?
       WHERE id = ?`,
      [
        decision.recommendedAction,
        "user",
        decision.user,
        "active",
        "simulated",
        Date.now(),
        null,
        existing.id
      ]
    );
    enforcement = await getEnforcementByDecisionId(decisionId);
  } else {
    const result = await db.run(
      `INSERT INTO enforcements
       (decisionId, action, targetType, targetId, status, mode, startedAt, endedAt)
       VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,
      [
        decisionId,
        decision.recommendedAction,
        "user",
        decision.user,
        "active",
        "simulated",
        Date.now(),
        null
      ]
    );
    enforcement = await db.get(`SELECT * FROM enforcements WHERE id = ?`, [
      result.lastID
    ]);
  }

  await addTimelineEntry({
    decisionId,
    actorType: "operator",
    actorId: operatorId,
    action: "executed",
    fromStatus: decision.status,
    toStatus: "executed",
    note: note || `Executed ${decision.recommendedAction} in simulated mode`
  });

  broadcast("enforcement", enforcement);
  return { ok: true, decision: updated, enforcement };
}

async function reverseDecision(decisionId, operatorId = "operator", note = "") {
  const decision = await getDecisionById(decisionId);
  if (!decision) return { error: "Decision not found", status: 404 };
  if (decision.status !== "executed") {
    return { error: "Only executed decisions can be reversed", status: 400 };
  }

  const enforcement = await getEnforcementByDecisionId(decisionId);
  if (enforcement) {
    await db.run(
      `UPDATE enforcements SET status = ?, endedAt = ? WHERE id = ?`,
      ["reversed", Date.now(), enforcement.id]
    );
  }

  const updated = await updateDecision(decisionId, {
    status: "reversed",
    actualAction: "reversed",
    note: note || decision.note
  });

  await addTimelineEntry({
    decisionId,
    actorType: "operator",
    actorId: operatorId,
    action: "reversed",
    fromStatus: decision.status,
    toStatus: "reversed",
    note
  });

  const updatedEnforcement = await getEnforcementByDecisionId(decisionId);
  if (updatedEnforcement) {
    broadcast("enforcement", updatedEnforcement);
  }

  return { ok: true, decision: updated, enforcement: updatedEnforcement || null };
}

async function assignDecision(decisionId, operatorId = "operator", assignedTo = null, note = "") {
  const decision = await getDecisionById(decisionId);
  if (!decision) return { error: "Decision not found", status: 404 };

  const updated = await updateDecision(decisionId, {
    assignedTo
  });

  await addTimelineEntry({
    decisionId,
    actorType: "operator",
    actorId: operatorId,
    action: "assigned",
    fromStatus: decision.status,
    toStatus: decision.status,
    note: note || `Assigned to ${assignedTo || "unassigned"}`
  });

  return { ok: true, decision: updated };
}

async function addDecisionNote(decisionId, operatorId = "operator", note = "") {
  const decision = await getDecisionById(decisionId);
  if (!decision) return { error: "Decision not found", status: 404 };

  const mergedNote = decision.note
    ? `${decision.note}\n[${new Date().toISOString()} ${operatorId}] ${note}`
    : `[${new Date().toISOString()} ${operatorId}] ${note}`;

  const updated = await updateDecision(decisionId, {
    note: mergedNote
  });

  await addTimelineEntry({
    decisionId,
    actorType: "operator",
    actorId: operatorId,
    action: "note_added",
    fromStatus: decision.status,
    toStatus: decision.status,
    note
  });

  return { ok: true, decision: updated };
}

// ====================
// Risk engine
// ====================
function calculateRisk(event) {
  let score = 0;

  score += event.risk || 0;

  if (event.type === "login" && (event.attempts || 0) > 3) {
    score += 15;
  }

  if (event.amount && event.amount > 5000) {
    score += 20;
  }

  const userKey = event.user || "unknown";
  const history = userHistory.get(userKey) || [];
  history.push(Date.now());

  if (history.length > 20) history.shift();
  userHistory.set(userKey, history);

  const recent = history.filter((t) => Date.now() - t < 60000);

  if (recent.length > 5) {
    score += 25;
  }

  if (event.ip === "unknown") {
    score += 10;
  }

  return Math.min(score, 100);
}

function shouldAlert(key, cooldownMs = 60000) {
  const last = alertCooldown.get(key);

  if (last && Date.now() - last < cooldownMs) {
    return false;
  }

  alertCooldown.set(key, Date.now());
  return true;
}

function decideAction(event, riskScore) {
  if (riskScore >= 85) return "block";
  if (riskScore >= 65) return "manual_review";
  if (riskScore >= 45) return "rate_limit";
  return "log";
}

// ====================
// Trend layer
// ====================
function updateTrend(event) {
  const userKey = event.user || "unknown";
  const now = Date.now();

  const current = trendStore.get(userKey) || {
    totalEvents: 0,
    recentTimestamps: [],
    avgRisk: 0,
    lastEventType: null,
    lastSeenAt: null
  };

  current.totalEvents += 1;
  current.lastEventType = event.type || "unknown";
  current.lastSeenAt = now;

  current.recentTimestamps.push(now);
  current.recentTimestamps = current.recentTimestamps.filter(
    (t) => now - t < 5 * 60 * 1000
  );

  const incomingRisk = event.risk || 0;
  current.avgRisk =
    current.totalEvents === 1
      ? incomingRisk
      : Math.round(
          ((current.avgRisk * (current.totalEvents - 1)) + incomingRisk) /
            current.totalEvents
        );

  trendStore.set(userKey, current);
  return current;
}

function detectTrendAnomaly(event) {
  const userKey = event.user || "unknown";
  const trend = trendStore.get(userKey);

  if (!trend) return null;

  const recentCount = trend.recentTimestamps.length;
  const incomingRisk = event.risk || 0;

  if (recentCount >= 6 && incomingRisk > trend.avgRisk + 20) {
    return {
      level: "high",
      reason: "User activity spike with elevated risk",
      baselineRisk: trend.avgRisk,
      recentEvents: recentCount
    };
  }

  if (recentCount >= 8) {
    return {
      level: "medium",
      reason: "User event frequency is above baseline",
      baselineRisk: trend.avgRisk,
      recentEvents: recentCount
    };
  }

  return null;
}

// ====================
// Correlation engine
// ====================
function detectCorrelation(events) {
  const now = Date.now();

  const recent = events.filter((e) => now - e.timestamp < 300000);

  const failedLogins = recent.filter(
    (e) => e.type === "login" && (e.attempts || 0) > 3
  ).length;

  const highPayments = recent.filter(
    (e) => e.amount && e.amount > 5000
  ).length;

  const unknownIPs = recent.filter(
    (e) => e.ip === "unknown"
  ).length;

  if (failedLogins >= 5 && highPayments >= 1 && unknownIPs >= 2) {
    return {
      level: "critical",
      reason: "Multi-signal attack pattern"
    };
  }

  return null;
}

async function buildAiSummary() {
  const recentIncidents = await getRecentIncidents(10);
  const recentActions = await getRecentActions(10);
  const recentDecisions = await getRecentDecisions(10);

  const critical = recentIncidents.filter((i) => i.severity === "critical").length;
  const high = recentIncidents.filter((i) => i.severity === "high").length;
  const medium = recentIncidents.filter((i) => i.severity === "medium").length;
  const low = recentIncidents.filter((i) => i.severity === "low").length;

  const blocked = recentActions.filter((a) => a.action === "block").length;
  const reviews = recentActions.filter((a) => a.action === "manual_review").length;
  const rateLimits = recentActions.filter((a) => a.action === "rate_limit").length;

  const pendingReviews = recentDecisions.filter((d) => d.status === "pending_review").length;
  const executed = recentDecisions.filter((d) => d.status === "executed").length;

  if (!recentIncidents.length) {
    return {
      summary: "System is live. No active incidents detected. Baseline monitoring remains calm.",
      counts: { critical, high, medium, low },
      actions: { blocked, reviews, rateLimits },
      decisions: { pendingReviews, executed }
    };
  }

  let tone = "System activity is stable.";
  if (critical > 0) {
    tone = "Critical risk patterns are active and require immediate attention.";
  } else if (high > 0) {
    tone = "High-risk incidents are present and should be reviewed promptly.";
  } else if (medium > 0) {
    tone = "Risk is elevated but remains manageable.";
  }

  return {
    summary:
      `${tone} ` +
      `Recent incidents: ${recentIncidents.length}. ` +
      `Critical: ${critical}, High: ${high}, Medium: ${medium}, Low: ${low}. ` +
      `Recent decisions: blocked ${blocked}, manual reviews ${reviews}, rate limits ${rateLimits}. ` +
      `Pending reviews: ${pendingReviews}, executed decisions: ${executed}.`,
    counts: { critical, high, medium, low },
    actions: { blocked, reviews, rateLimits },
    decisions: { pendingReviews, executed }
  };
}

// ====================
// Routes
// ====================
app.get("/health", (_req, res) => {
  res.json({ ok: true, service: "SignalDesk", ws: !!wss, db: !!db });
});

app.get("/api/incidents", async (_req, res) => {
  res.json(await getRecentIncidents());
});

app.get("/api/actions", async (_req, res) => {
  res.json(await getRecentActions());
});

app.get("/api/summary", async (_req, res) => {
  res.json(await buildAiSummary());
});

app.get("/api/decisions", async (req, res) => {
  const { status, action, assignedTo, limit } = req.query;

  const decisions = await getRecentDecisions(
    Number(limit) || 50,
    { status, action, assignedTo }
  );

  res.json(decisions);
});

app.get("/api/decisions/:id", async (req, res) => {
  const decisionId = Number(req.params.id);
  const decision = await getDecisionById(decisionId);

  if (!decision) {
    return res.status(404).json({ error: "Decision not found" });
  }

  const incident = await db.get(`SELECT * FROM incidents WHERE id = ?`, [
    decision.incidentId
  ]);

  const timeline = await getTimelineByDecisionId(decisionId);
  const enforcement = await getEnforcementByDecisionId(decisionId);

  res.json({
    decision,
    incident: incident
      ? {
          ...incident,
          correlation: parseMaybeJson(incident.correlation),
          trend: parseMaybeJson(incident.trend),
          trendAnomaly: parseMaybeJson(incident.trendAnomaly)
        }
      : null,
    timeline,
    enforcement: enforcement || null
  });
});

app.post("/api/decisions/:id/approve", async (req, res) => {
  const result = await approveDecision(
    Number(req.params.id),
    req.body.operatorId || "operator",
    req.body.note || ""
  );

  if (result.error) {
    return res.status(result.status).json({ ok: false, error: result.error });
  }

  res.json(result);
});

app.post("/api/decisions/:id/reject", async (req, res) => {
  const result = await rejectDecision(
    Number(req.params.id),
    req.body.operatorId || "operator",
    req.body.note || ""
  );

  if (result.error) {
    return res.status(result.status).json({ ok: false, error: result.error });
  }

  res.json(result);
});

app.post("/api/decisions/:id/execute", async (req, res) => {
  const result = await executeDecision(
    Number(req.params.id),
    req.body.operatorId || "operator",
    req.body.note || ""
  );

  if (result.error) {
    return res.status(result.status).json({ ok: false, error: result.error });
  }

  res.json(result);
});

app.post("/api/decisions/:id/reverse", async (req, res) => {
  const result = await reverseDecision(
    Number(req.params.id),
    req.body.operatorId || "operator",
    req.body.note || ""
  );

  if (result.error) {
    return res.status(result.status).json({ ok: false, error: result.error });
  }

  res.json(result);
});

app.post("/api/decisions/:id/assign", async (req, res) => {
  const result = await assignDecision(
    Number(req.params.id),
    req.body.operatorId || "operator",
    req.body.assignedTo || null,
    req.body.note || ""
  );

  if (result.error) {
    return res.status(result.status).json({ ok: false, error: result.error });
  }

  res.json(result);
});

app.post("/api/decisions/:id/note", async (req, res) => {
  const result = await addDecisionNote(
    Number(req.params.id),
    req.body.operatorId || "operator",
    req.body.note || ""
  );

  if (result.error) {
    return res.status(result.status).json({ ok: false, error: result.error });
  }

  res.json(result);
});

app.post("/event", async (req, res) => {
  try {
    const event = {
      ...req.body,
      timestamp: Date.now()
    };

    const trend = updateTrend(event);
    const trendAnomaly = detectTrendAnomaly(event);

    const riskScore = calculateRisk(event);
    let action = decideAction(event, riskScore);

    const incident = {
      ...event,
      riskScore,
      action,
      severity: severityFromRisk(riskScore),
      correlation: null,
      trend,
      trendAnomaly
    };

    globalEvents.push(incident);
    if (globalEvents.length > 100) {
      globalEvents.shift();
    }

    const correlation = detectCorrelation(globalEvents);
    incident.correlation = correlation;

    if (correlation?.level === "critical") {
      incident.action = "block";
      action = "block";
    } else if (trendAnomaly?.level === "high" && action !== "block") {
      incident.action = "manual_review";
      action = "manual_review";
    }

    const incidentId = await saveIncident(incident);
    const savedIncident = { ...incident, id: incidentId };

    broadcast("incident", savedIncident);

    const decision = await createDecisionFromIncident(incidentId, incident);

    const alertKey = `${event.type || "event"}_${event.user || "unknown"}`;
    const alertAllowed = shouldAlert(alertKey);

    let actionEntry = null;
    if (alertAllowed || action !== "log") {
      actionEntry = await pushAction(
        action,
        `Decision for ${event.type || "event"} on ${event.user || "unknown"}`,
        incident.severity,
        "Risk Engine"
      );
    }

    const aiSummary = await buildAiSummary();
    broadcast("summary", aiSummary);

    res.json({
      ok: true,
      risk: riskScore,
      action,
      correlation,
      trend,
      trendAnomaly,
      alert: alertAllowed
        ? {
            type: incident.type,
            severity: incident.severity,
            action: incident.action
          }
        : null,
      incident: savedIncident,
      decision,
      actionEntry
    });
  } catch (error) {
    console.error("❌ /event failed:", error);
    res.status(500).json({
      ok: false,
      error: error.message
    });
  }
});

app.get("*", (_req, res) => {
  res.sendFile(new URL("../public_dashboard/index.html", import.meta.url).pathname);
});

// ====================
// Server + WebSocket
// ====================
async function start() {
  await initDb();

  const server = http.createServer(app);
  wss = new WebSocketServer({ server });

  wss.on("connection", async (ws) => {
    console.log("✅ WebSocket client connected");

    ws.send(
      JSON.stringify({
        type: "bootstrap",
        payload: {
          incidents: await getRecentIncidents(),
          actions: await getRecentActions(),
          decisions: await getRecentDecisions(50),
          summary: await buildAiSummary()
        }
      })
    );
  });

  server.listen(PORT, async () => {
    console.log(`🚀 SignalDesk running on http://localhost:${PORT}`);

    await pushAction(
      "monitoring_initialized",
      "System boot completed and action tracking is live.",
      "low",
      "Core"
    );

    await pushAction(
      "baseline_safeguards_enabled",
      "Default operational rules loaded successfully.",
      "normal",
      "Core"
    );
  });
}

start().catch((error) => {
  console.error("❌ Failed to start SignalDesk:", error);
  process.exit(1);
});
