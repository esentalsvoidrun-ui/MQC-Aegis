<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SignalDesk — AI Decision Engine</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Inter, Arial, sans-serif;
      background: radial-gradient(circle at top, #071426 0%, #03101d 45%, #020b14 100%);
      color: #e5eef8;
    }

    .wrap {
      max-width: 1280px;
      margin: 0 auto;
      padding: 14px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
    }

    h1 {
      margin: 0;
      font-size: 28px;
      line-height: 1.1;
    }

    .sub {
      margin-top: 6px;
      color: #8ea3b7;
      font-size: 13px;
      max-width: 760px;
    }

    .statuspill {
      border: 1px solid rgba(255,255,255,.12);
      border-radius: 999px;
      padding: 8px 12px;
      font-size: 12px;
      color: #c9d7e5;
      background: rgba(255,255,255,.03);
      white-space: nowrap;
    }

    .minirow {
      display: flex;
      gap: 10px;
      margin-top: 8px;
      flex-wrap: wrap;
    }

    .mini {
      border: 1px solid rgba(255,255,255,.08);
      border-radius: 10px;
      padding: 6px 10px;
      font-size: 12px;
      color: #b5c6d8;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 14px;
      align-items: start;
    }

    .panel {
      border: 1px solid rgba(255,255,255,.1);
      border-radius: 16px;
      background: rgba(8, 20, 36, .82);
      box-shadow: 0 10px 40px rgba(0,0,0,.25);
      overflow: hidden;
    }

    .panelhead {
      padding: 12px 14px;
      border-bottom: 1px solid rgba(255,255,255,.08);
      font-size: 11px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: #89a1b8;
    }

    .panelbody {
      padding: 14px;
    }

    .stack {
      display: grid;
      gap: 14px;
    }

    #liveFeed, #incidentList, #actionList {
      min-height: 180px;
      max-height: 620px;
      overflow: auto;
    }

    @media (max-width: 1050px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div>
        <h1>SignalDesk — AI Decision Engine</h1>
        <div class="sub">
          Live analysis. Real-time signals. AI-backed decisions. Correlation support for people who do not have time for nonsense.
        </div>
        <div class="minirow">
          <div class="mini" id="authStatus">Booting operator mode</div>
          <div class="mini" id="connection-status">WS pending</div>
        </div>
      </div>
      <div class="statuspill">Operator board</div>
    </div>

    <div class="grid">
      <div class="stack">
        <div class="panel">
          <div class="panelhead">AI Summary</div>
          <div class="panelbody" id="aiSummary">Loading summary...</div>
        </div>

        <div class="panel">
          <div class="panelhead">Live Decision Feed</div>
          <div class="panelbody" id="liveFeed"></div>
        </div>
      </div>

      <div class="panel">
        <div class="panelhead">Incident Stream</div>
        <div class="panelbody" id="incidentList"></div>
      </div>

      <div class="panel">
        <div class="panelhead">Operator Actions</div>
        <div class="panelbody" id="actionList"></div>
      </div>
    </div>
  </div>

  <script src="/app.js"></script>
</body>
</html>
