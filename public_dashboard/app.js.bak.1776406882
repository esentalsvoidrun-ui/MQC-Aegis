const incidentList = document.getElementById("incidentList");
const actionList = document.getElementById("actionList");
const authStatus = document.getElementById("authStatus");
const connectionStatus = document.getElementById("connection-status");
const summaryBox = document.getElementById("summaryBox");

const apiBase = `${window.location.protocol}//${window.location.host}`;
const wsProtocol = window.location.protocol === "https:" ? "wss" : "ws";
const wsUrl = `${wsProtocol}://${window.location.host}`;

function escapeHtml(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function timeAgo(iso) {
  if (!iso) return "unknown";
  const diff = Date.now() - new Date(iso).getTime();
  const sec = Math.max(0, Math.floor(diff / 1000));

  if (sec < 5) return "just now";
  if (sec < 60) return `${sec}s ago`;

  const min = Math.floor(sec / 60);
  if (min < 60) return `${min}m ago`;

  const hr = Math.floor(min / 60);
  if (hr < 24) return `${hr}h ago`;

  const day = Math.floor(hr / 24);
  return `${day}d ago`;
}

function severityClass(severity) {
  switch (severity) {
    case "critical":
      return "sev-critical";
    case "high":
      return "sev-high";
    case "medium":
      return "sev-medium";
    default:
      return "sev-low";
  }
}

function actionLabel(action) {
  if (action === "block") return "Block";
  if (action === "manual_review") return "Manual review";
  if (action === "rate_limit") return "Rate limit";
  return "Log";
}

function renderSummary(data) {
  if (!summaryBox) return;

  const summary = data?.summary || "No summary yet.";
  const recommendation = data?.recommendation || "Continue monitoring.";
  const stats = data?.stats || {};

  summaryBox.innerHTML = `
    <div class="sd-card">
      <div class="sd-card-header">
        <div>
          <div class="sd-eyebrow">AI Insights</div>
          <div class="sd-title">Operational Summary</div>
        </div>
      </div>

      <div class="sd-summary-text">${escapeHtml(summary)}</div>
      <div class="sd-summary-rec">${escapeHtml(recommendation)}</div>

      <div class="sd-stat-row">
        <div class="sd-stat">
          <div class="sd-stat-value">${stats.incidents ?? 0}</div>
          <div class="sd-stat-label">Incidents</div>
        </div>
        <div class="sd-stat">
          <div class="sd-stat-value">${stats.critical ?? 0}</div>
          <div class="sd-stat-label">Critical</div>
        </div>
        <div class="sd-stat">
          <div class="sd-stat-value">${stats.high ?? 0}</div>
          <div class="sd-stat-label">High</div>
        </div>
        <div class="sd-stat">
          <div class="sd-stat-value">${stats.recurring ?? 0}</div>
          <div class="sd-stat-label">Recurring</div>
        </div>
      </div>
    </div>
  `;
}

function renderIncidents(items = []) {
  if (!incidentList) return;

  if (!items.length) {
    incidentList.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents yet</div>
        <div class="sd-empty-sub">The watch floor is quiet. Enjoy it while it lasts.</div>
      </div>
    `;
    return;
  }

  incidentList.innerHTML = items
    .map((incident) => {
      const repeatCount = incident.repeatCount || 1;
      const recurring = repeatCount > 1;

      const repeatBadge = recurring
        ? `<span class="sd-badge sd-badge-recurring">Recurring x${repeatCount}</span>`
        : `<span class="sd-badge">First seen</span>`;

      const severityBadge = `<span class="sd-badge ${severityClass(
        incident.severity
      )}">${escapeHtml((incident.severity || "low").toUpperCase())}</span>`;

      const actionBadge = `<span class="sd-badge sd-badge-action">${escapeHtml(
        actionLabel(incident.action)
      )}</span>`;

      const reasons = (incident.reasonCodes || [])
        .map((reason) => `<span class="sd-chip">${escapeHtml(reason)}</span>`)
        .join("");

      const pressureText = recurring
        ? `Seen again ${timeAgo(incident.lastSeenAt)}`
        : `Opened ${timeAgo(incident.createdAt)}`;

      return `
        <div class="sd-card incident-card ${severityClass(incident.severity)}">
          <div class="sd-card-header">
            <div>
              <div class="sd-eyebrow">Incident #${incident.id}</div>
              <div class="sd-title">${escapeHtml(incident.type || "unknown")} · ${escapeHtml(
        incident.user || "anonymous"
      )}</div>
            </div>
            <div class="sd-badge-row">
              ${severityBadge}
              ${actionBadge}
              ${repeatBadge}
            </div>
          </div>

          <div class="sd-meta-row">
            <div><strong>Risk:</strong> ${incident.riskScore ?? 0}</div>
            <div><strong>Status:</strong> ${escapeHtml(incident.status || "pending_review")}</div>
            <div><strong>SLA:</strong> ${escapeHtml(incident.sla || "-")}</div>
            <div><strong>IP:</strong> ${escapeHtml(incident.ip || "-")}</div>
          </div>

          <div class="sd-meta-row">
            <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
            <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
            <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
            <div><strong>Repeats:</strong> ${repeatCount}</div>
          </div>

          <div class="sd-pressure ${recurring ? "sd-pressure-hot" : ""}">
            ${escapeHtml(pressureText)}
          </div>

          ${
            incident.correlationLabel && incident.correlationLabel !== "none"
              ? `<div class="sd-note"><strong>Correlation:</strong> ${escapeHtml(
                  incident.correlationLabel
                )}</div>`
              : ""
          }

          ${
            incident.trendLabel && incident.trendLabel !== "normal"
              ? `<div class="sd-note"><strong>Trend:</strong> ${escapeHtml(
                  incident.trendLabel
                )}</div>`
              : ""
          }

          <div class="sd-chip-row">${reasons || `<span class="sd-chip">No reason codes</span>`}</div>
        </div>
      `;
    })
    .join("");
}

function renderActions(items = []) {
  if (!actionList) return;

  if (!items.length) {
    actionList.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No actions yet</div>
        <div class="sd-empty-sub">No queued actions. For once, the machine is behaving.</div>
      </div>
    `;
    return;
  }

  actionList.innerHTML = items
    .map(
      (action) => `
        <div class="sd-card action-card">
          <div class="sd-card-header">
            <div>
              <div class="sd-eyebrow">Action #${action.id}</div>
              <div class="sd-title">${escapeHtml(action.title || action.type || "Action")}</div>
            </div>
            <div class="sd-badge-row">
              <span class="sd-badge ${severityClass(action.severity)}">${escapeHtml(
        (action.severity || "low").toUpperCase()
      )}</span>
            </div>
          </div>

          <div class="sd-meta-row">
            <div><strong>User:</strong> ${escapeHtml(action.user || "-")}</div>
            <div><strong>Status:</strong> ${escapeHtml(action.status || "pending")}</div>
            <div><strong>Type:</strong> ${escapeHtml(action.type || "-")}</div>
            <div><strong>Created:</strong> ${timeAgo(action.createdAt)}</div>
          </div>
        </div>
      `
    )
    .join("");
}

async function fetchJson(path) {
  const res = await fetch(`${apiBase}${path}`);
  if (!res.ok) {
    throw new Error(`HTTP ${res.status} on ${path}`);
  }
  return res.json();
}

async function refreshAll() {
  try {
    const [incidents, actions, summary] = await Promise.all([
      fetchJson("/api/incidents"),
      fetchJson("/api/actions"),
      fetchJson("/api/summary")
    ]);

    renderIncidents(incidents);
    renderActions(actions);
    renderSummary(summary);

    if (authStatus) authStatus.textContent = "Live";
  } catch (error) {
    console.error(error);
    if (authStatus) authStatus.textContent = "API error";
  }
}

function connectWs() {
  const socket = new WebSocket(wsUrl);

  socket.addEventListener("open", () => {
    if (connectionStatus) connectionStatus.textContent = "WS connected";
  });

  socket.addEventListener("close", () => {
    if (connectionStatus) connectionStatus.textContent = "WS disconnected";
    setTimeout(connectWs, 1500);
  });

  socket.addEventListener("message", (event) => {
    try {
      const payload = JSON.parse(event.data);

      if (payload.type === "bootstrap") {
        renderIncidents(payload.incidents || []);
        renderActions(payload.actions || []);
        renderSummary(payload.summary || {});
        return;
      }

      if (
        payload.type === "incident_created" ||
        payload.type === "incident_merged" ||
        payload.type === "action_created"
      ) {
        refreshAll();
      }
    } catch (error) {
      console.error("WS parse error", error);
    }
  });
}

