  const style = document.createElement("style");
  style.id = "sd-case-detail-styles";
  style.textContent = `
    .sd-clickable {
      cursor: pointer;
      transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
    }

    .sd-clickable:hover {
      transform: translateY(-1px);
    }

    .sd-selected {
      border-color: rgba(120,160,255,0.38) !important;
      box-shadow: 0 0 0 1px rgba(120,160,255,0.18), 0 10px 26px rgba(0,0,0,0.22);
    }

    .sd-detail-wrap {
      display: grid;
      gap: 10px;
    }

    .sd-detail-title {
      font-size: 15px;
      font-weight: 800;
      line-height: 1.25;
      word-break: break-word;
    }

    .sd-detail-section {
      padding-top: 10px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .sd-detail-label {
      font-size: 10px;
