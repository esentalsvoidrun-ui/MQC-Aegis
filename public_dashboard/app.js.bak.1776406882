      font-size: 11px;
    }

    .sd-mini-history-time {
      opacity: 0.65;
      margin-bottom: 4px;
      font-weight: 700;
    }
  `;
  document.head.appendChild(style);
})();

function getSelectedIncident(items = []) {
  if (!items.length) return null;

  const selected =
    items.find((incident) => Number(incident.id) === Number(selectedIncidentId)) || null;

  if (selected) return selected;

  return items[0];
}

function renderCaseDetailPanel(allItems = []) {
  const panel =
    document.getElementById("caseDetail") ||
    document.getElementById("case-detail") ||
    document.getElementById("caseDetailPanel");

  if (!panel) return;

  const incident = getSelectedIncident(allItems);

  if (!incident) {
    panel.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No case selected</div>
        <div class="sd-empty-sub">Choose an incident from the queue to inspect it here.</div>
      </div>
    `;
    return;
  }

  const audit = Array.isArray(incident.auditTrail) ? incident.auditTrail.slice(0, 8) : [];

  panel.innerHTML = `
    <div class="sd-detail-wrap">
      <div>
        <div class="sd-eyebrow">Case Detail</div>
        <div class="sd-detail-title">${escapeHtml(incident.type)} · ${escapeHtml(incident.user)}</div>
      </div>

      <div class="sd-badge-row">
        <span class="sd-badge ${severityClass(incident.severity)}">${escapeHtml((incident.severity || "low").toUpperCase())}</span>
        <span class="sd-badge sd-badge-action">${escapeHtml(actionLabel(incident.action))}</span>
        <span class="sd-badge">${escapeHtml(incident.status || "pending_review")}</span>
      </div>

      <div class="sd-detail-section">
        <div class="sd-detail-label">Case facts</div>
        <div class="sd-detail-grid">
          <div><strong>ID:</strong> ${incident.id}</div>
          <div><strong>Risk:</strong> ${incident.riskScore}</div>
          <div><strong>Repeats:</strong> ${incident.repeatCount || 1}</div>
          <div><strong>SLA:</strong> ${escapeHtml(incident.sla || "-")}</div>
          <div><strong>Assigned:</strong> ${escapeHtml(incident.assignedTo || "unassigned")}</div>
          <div><strong>Last operator:</strong> ${escapeHtml(incident.lastOperator || "none")}</div>
          <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
          <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
          <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
        </div>
      </div>

      <div class="sd-detail-section">
        <div class="sd-detail-label">Reason codes</div>
        <div class="sd-detail-chiprow">
          ${(incident.reasonCodes || []).map(code => `<span class="sd-chip">${escapeHtml(code)}</span>`).join("") || `<span class="sd-chip">No reason codes</span>`}
        </div>
      </div>

      ${
        incident.correlationLabel && incident.correlationLabel !== "none"
          ? `
      <div class="sd-detail-section">
        <div class="sd-detail-label">Correlation</div>
        <div>${escapeHtml(incident.correlationLabel)}</div>
      </div>`
          : ""
      }

      ${
        incident.trendLabel && incident.trendLabel !== "normal"
          ? `
      <div class="sd-detail-section">
        <div class="sd-detail-label">Trend</div>
        <div>${escapeHtml(incident.trendLabel)}</div>
      </div>`
          : ""
      }

      <div class="sd-detail-section">
        <div class="sd-detail-label">Recent audit trail</div>
        <div class="sd-mini-history">
          ${
            audit.length
              ? audit
                  .map((entry) => {
                    const mapped = mapAuditTypeToText(entry, incident);
                    return `
                      <div class="sd-mini-history-item">
                        <div class="sd-mini-history-time">${timeAgo(entry.at)}</div>
                        <div>${escapeHtml(mapped.text)}</div>
                      </div>
                    `;
                  })
                  .join("")
              : `<div class="sd-empty-sub">No audit entries yet.</div>`
          }
        </div>
      </div>
    </div>
  `;
}

// =======================
// PATCH renderIncidents TO SUPPORT SELECTION
// =======================

renderIncidents = function(items = []) {
  if (!incidentList) return;

  latestIncidentSnapshot = items;
  const filteredItems = applyIncidentFilters(items);
  const visibleItems = sortIncidents(filteredItems);

  if (!selectedIncidentId && items.length) {
    selectedIncidentId = items[0].id;
  }

  if (!items.length) {
    incidentList.innerHTML = `
      <div class="sd-incident-shell">
        ${renderIncidentFilterBar(items, visibleItems)}
        <div class="sd-empty">
          <div class="sd-empty-title">No incidents yet</div>
          <div class="sd-empty-sub">The watch floor is quiet. Enjoy it while it lasts.</div>
        </div>
      </div>
    `;
    renderCaseDetailPanel(items);
    return;
  }

  if (!visibleItems.length) {
    incidentList.innerHTML = `
      <div class="sd-incident-shell">
        ${renderIncidentFilterBar(items, visibleItems)}
        <div class="sd-empty">
          <div class="sd-empty-title">No incidents match the current filter</div>
          <div class="sd-empty-sub">Try widening the net. Even old sea captains did not inspect the whole ocean through a keyhole.</div>
        </div>
      </div>
    `;
    renderCaseDetailPanel(items);
    return;
  }

  incidentList.innerHTML = `
    <div class="sd-incident-shell">
      ${renderIncidentFilterBar(items, visibleItems)}
      <div class="sd-incident-grid">
        ${visibleItems.map((incident) => {
          const repeatCount = incident.repeatCount || 1;
          const pressure = getPressureLevel(incident);
          const fresh = isFresh(incident.lastSeenAt);
          const rawStatus = String(incident.status || "pending_review");
          const status = escapeHtml(rawStatus);
          const buttonState = getButtonState(incident);
          const isSelected = Number(selectedIncidentId) === Number(incident.id);

          const repeatBadgeClass =
            repeatCount >= 5 ? "sd-badge sd-badge-hot" :
            repeatCount >= 3 ? "sd-badge sev-high" :
            repeatCount >= 2 ? "sd-badge sd-badge-recurring" :
            "sd-badge";

          const repeatBadge = `
            <span class="${repeatBadgeClass}">
              ${repeatCount > 1 ? `Recurring x${repeatCount}` : "First seen"}
            </span>
          `;

          const freshnessDot = fresh ? `<span class="fresh-dot"></span>` : "";

          return `
            <div class="sd-card incident-card sd-clickable ${pressure} ${isSelected ? "sd-selected" : ""}"
                 onclick="selectIncident(${incident.id})">
              <div class="sd-card-header">
                <div>
                  <div class="sd-eyebrow">
                    Incident #${incident.id} ${freshnessDot}
                  </div>
                  <div class="sd-title">
                    ${escapeHtml(incident.type)} · ${escapeHtml(incident.user)}
                  </div>
                </div>

                <div class="sd-badge-row">
                  <span class="sd-badge ${severityClass(incident.severity)}">
                    ${escapeHtml((incident.severity || "low").toUpperCase())}
                  </span>

                  <span class="sd-badge sd-badge-action">
                    ${escapeHtml(actionLabel(incident.action))}
                  </span>

                  ${repeatBadge}
                </div>
              </div>

              <div class="sd-meta-row">
                <div><strong>Risk:</strong> ${incident.riskScore}</div>
                <div><strong>Status:</strong> <span class="sd-status-pill ${status}">${status}</span></div>
                <div><strong>SLA:</strong> ${escapeHtml(incident.sla)}</div>
                <div><strong>Repeats:</strong> ${repeatCount}</div>
              </div>

              <div class="sd-meta-row">
                <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
                <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
                <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
                <div><strong>Assigned:</strong> ${escapeHtml(incident.assignedTo || "unassigned")}</div>
              </div>

              <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
                ${repeatCount > 1 ? `Pattern repeating (${repeatCount}x)` : "Single occurrence"}
              </div>

              <div class="sd-chip-row">
                ${(incident.reasonCodes || [])
                  .map(r => `<span class="sd-chip">${escapeHtml(r)}</span>`)
                  .join("")}
              </div>

              ${renderTimeline(incident)}
              ${renderCaseHistory(incident)}

              <div class="sd-operator-bar" onclick="event.stopPropagation()">
                <div class="sd-operator-row">
                  <input
                    id="operator-input-${incident.id}"
                    class="sd-operator-input"
                    type="text"
                    placeholder="Operator name"
                    value="${escapeHtml(incident.assignedTo || incident.lastOperator || "Robert")}"
                  />
                </div>

                <div class="sd-operator-actions">
                  <button
                    class="sd-btn sd-btn-assign"
                    onclick="assignIncident(${incident.id})"
                    ${buttonState.assignDisabled ? "disabled" : ""}
                  >
                    ${buttonState.assignLabel}
                  </button>

                  <button
                    class="sd-btn sd-btn-ack"
                    onclick="acknowledgeIncident(${incident.id})"
                    ${buttonState.ackDisabled ? "disabled" : ""}
                  >
                    ${buttonState.ackLabel}
                  </button>

                  <button
                    class="sd-btn sd-btn-resolve"
                    onclick="resolveIncident(${incident.id})"
                    ${buttonState.resolveDisabled ? "disabled" : ""}
                  >
                    ${buttonState.resolveLabel}
                  </button>
                </div>

                <div class="sd-operator-meta">
                  <span><strong>Last operator:</strong> ${escapeHtml(incident.lastOperator || "none")}</span>
                </div>

                <div id="operator-feedback-${incident.id}"></div>
              </div>
            </div>
          `;
        }).join("")}
      </div>
    </div>
  `;

  visibleItems.forEach((incident) => renderOperatorFeedback(incident.id));
  renderCaseDetailPanel(items);
};


// =======================
// ACTION LOG + LIVE EVENT FEED PANELS
// =======================

(function injectSidePanelStyles() {
  if (document.getElementById("sd-sidepanel-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-sidepanel-styles";
  style.textContent = `
    .sd-side-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sd-side-item {
      padding: 8px;
      border-radius: 10px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      font-size: 11px;
      line-height: 1.35;
    }

    .sd-side-time {
      opacity: 0.62;
      font-size: 10px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .sd-side-title {
      font-weight: 700;
      margin-bottom: 3px;
      word-break: break-word;
    }

    .sd-side-meta {
      opacity: 0.82;
      word-break: break-word;
    }
  `;
  document.head.appendChild(style);
})();

function renderActionLogPanel(items = []) {
  const panel =
    document.getElementById("actionLog") ||
    document.getElementById("action-log") ||
    document.getElementById("actionLogPanel");

  if (!panel) return;

  if (!items.length) {
    panel.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No actions yet</div>
        <div class="sd-empty-sub">No queued actions. The engine is quiet for now.</div>
      </div>
    `;
    return;
  }

  const recent = items.slice(0, 8);

  panel.innerHTML = `
    <div class="sd-side-list">
      ${recent.map((action) => `
        <div class="sd-side-item">
          <div class="sd-side-time">${timeAgo(action.createdAt)}</div>
          <div class="sd-side-title">${escapeHtml(action.title || action.type || "Action")}</div>
          <div class="sd-side-meta">
            <div><strong>User:</strong> ${escapeHtml(action.user || "-")}</div>
            <div><strong>Status:</strong> ${escapeHtml(action.status || "pending")}</div>
            <div><strong>Severity:</strong> ${escapeHtml(action.severity || "low")}</div>
          </div>
        </div>
      `).join("")}
    </div>
  `;
}

function buildLiveEventFeedFromIncidents(items = []) {
  const events = [];

  items.forEach((incident) => {
    events.push({
      at: incident.updatedAt || incident.createdAt,
      title: `${incident.type} · ${incident.user}`,
      meta: `Status ${incident.status || "pending_review"} · Risk ${incident.riskScore || 0} · Repeats ${incident.repeatCount || 1}`
    });

    if (Array.isArray(incident.auditTrail)) {
      incident.auditTrail.slice(0, 3).forEach((entry) => {
        const mapped = mapAuditTypeToText(entry, incident);
        events.push({
          at: entry.at,
          title: mapped.text,
          meta: `${incident.type} · ${incident.user}`
        });
      });
    }
  });

  return events
    .sort((a, b) => new Date(b.at || 0).getTime() - new Date(a.at || 0).getTime())
    .slice(0, 10);
}

function renderLiveEventFeedPanel(incidents = []) {
  const panel =
    document.getElementById("liveEventFeed") ||
    document.getElementById("live-event-feed") ||
    document.getElementById("liveEventFeedPanel");

  if (!panel) return;

  const feed = buildLiveEventFeedFromIncidents(incidents);

  if (!feed.length) {
    panel.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No live events</div>
        <div class="sd-empty-sub">Nothing is hitting the engine right now.</div>
      </div>
    `;
    return;
  }

  panel.innerHTML = `
    <div class="sd-side-list">
      ${feed.map((item) => `
        <div class="sd-side-item">
          <div class="sd-side-time">${timeAgo(item.at)}</div>
          <div class="sd-side-title">${escapeHtml(item.title)}</div>
          <div class="sd-side-meta">${escapeHtml(item.meta || "")}</div>
        </div>
      `).join("")}
    </div>
  `;
}

// =======================
// PATCH refreshAll TO UPDATE SIDE PANELS
// =======================

const originalRefreshAll = refreshAll;

refreshAll = async function() {
  try {
    const [incidents, actions, summary] = await Promise.all([
      fetchJson("/api/incidents"),
      fetchJson("/api/actions"),
      fetchJson("/api/summary")
    ]);

    latestIncidentSnapshot = incidents;
    renderIncidents(incidents);
    renderActions(actions);
    renderSummary(summary);
    renderCaseDetailPanel(incidents);
    renderActionLogPanel(actions);
    renderLiveEventFeedPanel(incidents);

    if (authStatus) authStatus.textContent = "Live";
  } catch (error) {
    console.error(error);
    if (authStatus) authStatus.textContent = "API error";
  }
};


// =======================
// TOP KPI + TREND + PRESSURE PANELS
// =======================

(function injectTopPanelStyles() {
  if (document.getElementById("sd-top-panel-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-top-panel-styles";
  style.textContent = `
    .sd-kpi-value {
      font-size: 34px;
      font-weight: 800;
      line-height: 1;
      margin-top: 6px;
      margin-bottom: 4px;
    }

    .sd-kpi-sub {
      font-size: 12px;
      opacity: 0.74;
      line-height: 1.35;
    }

    .sd-mini-stack {
      display: grid;
      gap: 8px;
    }

    .sd-mini-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 12px;
      padding: 7px 0;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .sd-mini-row:last-child {
      border-bottom: 0;
    }

    .sd-sparkbar-wrap {
      display: grid;
      gap: 10px;
    }

    .sd-sparkbar {
      height: 10px;
      border-radius: 999px;
      overflow: hidden;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .sd-sparkbar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(120,160,255,0.45), rgba(255,90,90,0.85));
    }

    .sd-panel-note {
      font-size: 12px;
      opacity: 0.8;
      line-height: 1.4;
    }
  `;
  document.head.appendChild(style);
})();

function getPanelElement(possibleIds = []) {
  for (const id of possibleIds) {
    const el = document.getElementById(id);
    if (el) return el;
  }
  return null;
}

function countCritical(incidents = []) {
  return incidents.filter((x) => x.severity === "critical" && x.status !== "resolved").length;
}

function countPending(incidents = []) {
  return incidents.filter((x) => x.status === "pending_review").length;
}

function countExecuted(actions = []) {
  return actions.filter((x) => x.status === "executed" || x.status === "done").length;
}

function computeRiskTrendStats(incidents = []) {
  const recent = incidents.slice(0, 12);
  const avgRisk =
    recent.length
      ? Math.round(recent.reduce((sum, x) => sum + Number(x.riskScore || 0), 0) / recent.length)
      : 0;

  const recurring = recent.filter((x) => (x.repeatCount || 1) > 1).length;
  const spiking = recent.filter((x) => x.trendLabel === "spike").length;

  return { avgRisk, recurring, spiking };
}

function computePressureStats(incidents = []) {
  const open = incidents.filter((x) => x.status !== "resolved");
  const pressurePoints = open.reduce((sum, x) => {
    const repeats = x.repeatCount || 1;
    const severityWeight =
      x.severity === "critical" ? 4 :
      x.severity === "high" ? 3 :
      x.severity === "medium" ? 2 : 1;

    return sum + repeats * severityWeight;
  }, 0);

  const normalized = Math.min(100, pressurePoints * 4);
  return {
    openCount: open.length,
    pressurePoints,
    normalized
  };
}

function renderCriticalKpi(incidents = []) {
  const panel = getPanelElement(["criticalCard", "criticalCount", "criticalPanel"]);
  if (!panel) return;

  const value = countCritical(incidents);

  panel.innerHTML = `
    <div class="sd-eyebrow">Critical</div>
    <div class="sd-kpi-value">${value}</div>
    <div class="sd-kpi-sub">Open critical incidents requiring immediate attention.</div>
  `;
}

function renderPendingKpi(incidents = []) {
  const panel = getPanelElement(["pendingCard", "pendingCount", "pendingPanel"]);
  if (!panel) return;

  const value = countPending(incidents);

  panel.innerHTML = `
    <div class="sd-eyebrow">Pending</div>
    <div class="sd-kpi-value">${value}</div>
    <div class="sd-kpi-sub">Cases still waiting for human acknowledgement.</div>
  `;
}

function renderExecutedKpi(actions = []) {
  const panel = getPanelElement(["executedCard", "executedCount", "executedPanel"]);
  if (!panel) return;

  const value = countExecuted(actions);

  panel.innerHTML = `
    <div class="sd-eyebrow">Executed</div>
    <div class="sd-kpi-value">${value}</div>
    <div class="sd-kpi-sub">Actions completed by operator or system flow.</div>
  `;
}

function renderRiskTrendPanel(incidents = []) {
  const panel = getPanelElement(["riskTrend", "riskTrendPanel", "risk-trend"]);
  if (!panel) return;

  const stats = computeRiskTrendStats(incidents);
  const fill = Math.max(6, stats.avgRisk);

  panel.innerHTML = `
    <div class="sd-mini-stack">
      <div class="sd-eyebrow">Risk Trend</div>
      <div class="sd-sparkbar-wrap">
        <div class="sd-sparkbar">
          <div class="sd-sparkbar-fill" style="width:${fill}%"></div>
        </div>
        <div class="sd-panel-note">
          Average recent risk is <strong>${stats.avgRisk}</strong>. Recurring cases: <strong>${stats.recurring}</strong>. Spike-labelled cases: <strong>${stats.spiking}</strong>.
        </div>
      </div>
    </div>
  `;
}

function renderIncidentPressurePanel(incidents = []) {
  const panel = getPanelElement(["incidentPressure", "incidentPressurePanel", "incident-pressure"]);
  if (!panel) return;

  const stats = computePressureStats(incidents);

  panel.innerHTML = `
    <div class="sd-mini-stack">
      <div class="sd-eyebrow">Incident Pressure</div>

      <div class="sd-sparkbar-wrap">
        <div class="sd-sparkbar">
          <div class="sd-sparkbar-fill" style="width:${Math.max(4, stats.normalized)}%"></div>
        </div>
      </div>

      <div class="sd-mini-row">
        <span>Open cases</span>
        <strong>${stats.openCount}</strong>
      </div>
      <div class="sd-mini-row">
        <span>Pressure points</span>
        <strong>${stats.pressurePoints}</strong>
      </div>
      <div class="sd-mini-row">
        <span>Normalized load</span>
        <strong>${stats.normalized}%</strong>
      </div>
    </div>
  `;
}

// =======================
// PATCH refreshAll AGAIN TO UPDATE TOP PANELS
// =======================

const refreshAllWithSidePanels = refreshAll;

refreshAll = async function() {
  try {
    const [incidents, actions, summary] = await Promise.all([
      fetchJson("/api/incidents"),
      fetchJson("/api/actions"),
      fetchJson("/api/summary")
    ]);

    latestIncidentSnapshot = incidents;

    renderIncidents(incidents);
    renderActions(actions);
    renderSummary(summary);
    renderCaseDetailPanel(incidents);
    renderActionLogPanel(actions);
    renderLiveEventFeedPanel(incidents);

    renderCriticalKpi(incidents);
    renderPendingKpi(incidents);
    renderExecutedKpi(actions);
    renderRiskTrendPanel(incidents);
    renderIncidentPressurePanel(incidents);

    if (authStatus) authStatus.textContent = "Live";
  } catch (error) {
    console.error(error);
    if (authStatus) authStatus.textContent = "API error";
  }
};

