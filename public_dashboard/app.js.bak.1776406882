injectStyles();
refreshAll();
connectWs();
setInterval(refreshAll, 10000);

// =======================
// HEAT / PRESSURE LOGIC
// =======================

function getPressureLevel(incident) {
  const count = incident.repeatCount || 1;

  if (count >= 5) return "critical";
  if (count >= 3) return "high";
  if (count >= 2) return "elevated";
  return "normal";
}

function isFresh(iso) {
  if (!iso) return false;
  return (Date.now() - new Date(iso).getTime()) < 10000; // 10s
}

// Inject extra styles
(function injectHeatStyles() {
  if (document.getElementById("sd-heat-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-heat-styles";
  style.textContent = `
    .incident-card.elevated {
      box-shadow: 0 0 12px rgba(180,120,255,0.25);
    }

    .incident-card.high {
      box-shadow: 0 0 18px rgba(255,166,0,0.35);
      border-color: rgba(255,166,0,0.4);
    }

    .incident-card.critical {
      box-shadow: 0 0 28px rgba(255,60,60,0.55);
      border-color: rgba(255,60,60,0.6);
      animation: pulseBorder 1.6s infinite;
    }

    @keyframes pulseBorder {
      0% { box-shadow: 0 0 10px rgba(255,60,60,0.4); }
      50% { box-shadow: 0 0 32px rgba(255,60,60,0.9); }
      100% { box-shadow: 0 0 10px rgba(255,60,60,0.4); }
    }

    .sd-badge-hot {
      background: rgba(255,60,60,0.25);
      border-color: rgba(255,60,60,0.6);
      animation: pulseBadge 1.6s infinite;
    }

    @keyframes pulseBadge {
      0% { transform: scale(1); }
      50% { transform: scale(1.08); }
      100% { transform: scale(1); }
    }

    .fresh-dot {
      display:inline-block;
      width:8px;
      height:8px;
      border-radius:50%;
      background:#00ffcc;
      margin-left:6px;
      animation: pulseDot 1s infinite;
    }

    @keyframes pulseDot {
      0% { opacity:0.4; }
      50% { opacity:1; }
      100% { opacity:0.4; }
    }
  `;
  document.head.appendChild(style);
})();


// =======================
// PATCH renderIncidents
// =======================

const originalRenderIncidents = renderIncidents;

renderIncidents = function(items = []) {
  if (!incidentList) return;

  if (!items.length) {
    incidentList.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents yet</div>
        <div class="sd-empty-sub">The watch floor is quiet. Enjoy it while it lasts.</div>
      </div>
    `;
    return;
  }

  incidentList.innerHTML = items.map((incident) => {
    const repeatCount = incident.repeatCount || 1;
    const pressure = getPressureLevel(incident);
    const fresh = isFresh(incident.lastSeenAt);

    const repeatBadgeClass =
      repeatCount >= 5 ? "sd-badge sd-badge-hot" :
      repeatCount >= 3 ? "sd-badge sev-high" :
      repeatCount >= 2 ? "sd-badge sd-badge-recurring" :
      "sd-badge";

    const repeatBadge = `
      <span class="${repeatBadgeClass}">
        ${repeatCount > 1 ? `Recurring x${repeatCount}` : "First seen"}
      </span>
    `;

    const freshnessDot = fresh ? `<span class="fresh-dot"></span>` : "";

    return `
      <div class="sd-card incident-card ${pressure}">
        <div class="sd-card-header">
          <div>
            <div class="sd-eyebrow">
              Incident #${incident.id} ${freshnessDot}
            </div>
            <div class="sd-title">
              ${incident.type} · ${incident.user}
            </div>
          </div>

          <div class="sd-badge-row">
            <span class="sd-badge ${severityClass(incident.severity)}">
              ${incident.severity.toUpperCase()}
            </span>

            <span class="sd-badge sd-badge-action">
              ${actionLabel(incident.action)}
            </span>

            ${repeatBadge}
          </div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Risk:</strong> ${incident.riskScore}</div>
          <div><strong>Status:</strong> ${incident.status}</div>
          <div><strong>SLA:</strong> ${incident.sla}</div>
          <div><strong>Repeats:</strong> ${repeatCount}</div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
          <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
          <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
        </div>

        <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
          ${repeatCount > 1
            ? `Pattern repeating (${repeatCount}x)`
            : "Single occurrence"}
        </div>

        <div class="sd-chip-row">
          ${(incident.reasonCodes || [])
            .map(r => `<span class="sd-chip">${r}</span>`)
            .join("")}
        </div>
      </div>
    `;
  }).join("");
};


// =======================
// ESCALATION TIMELINE
// =======================

function getEscalationLabel(incident) {
  const count = incident.repeatCount || 1;
  if (count >= 5) return "critical pressure";
  if (count >= 3) return "persistent";
  if (count >= 2) return "recurring";
  return "initial";
}

(function injectTimelineStyles() {
  if (document.getElementById("sd-timeline-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-timeline-styles";
  style.textContent = `
    .sd-timeline {
      margin-top: 12px;
      padding-top: 10px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .sd-timeline-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.68;
      margin-bottom: 8px;
    }

    .sd-timeline-track {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin-bottom: 8px;
    }

    .sd-step {
      position: relative;
      padding: 8px 6px;
      border-radius: 10px;
      font-size: 10px;
      text-align: center;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.08);
      opacity: 0.45;
    }

    .sd-step.active {
      opacity: 1;
      background: rgba(255,255,255,0.08);
    }

    .sd-step.elevated {
      border-color: rgba(177,120,255,0.38);
      box-shadow: 0 0 10px rgba(177,120,255,0.16);
    }

    .sd-step.high {
      border-color: rgba(255,166,0,0.42);
      box-shadow: 0 0 12px rgba(255,166,0,0.18);
    }

    .sd-step.critical {
      border-color: rgba(255,70,70,0.5);
      box-shadow: 0 0 16px rgba(255,70,70,0.22);
    }

    .sd-timeline-meta {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
      gap: 8px;
      font-size: 11px;
      opacity: 0.8;
    }
  `;
  document.head.appendChild(style);
})();

function renderTimeline(incident) {
  const count = incident.repeatCount || 1;

  const stages = [
    { key: "initial", label: "Initial", active: count >= 1, cls: "active" },
    { key: "recurring", label: "Recurring", active: count >= 2, cls: count >= 2 ? "active elevated" : "" },
    { key: "persistent", label: "Persistent", active: count >= 3, cls: count >= 3 ? "active high" : "" },
    { key: "critical", label: "Critical", active: count >= 5, cls: count >= 5 ? "active critical" : "" }
  ];

  return `
    <div class="sd-timeline">
      <div class="sd-timeline-title">Escalation timeline · ${getEscalationLabel(incident)}</div>
      <div class="sd-timeline-track">
        ${stages.map(stage => `
          <div class="sd-step ${stage.cls}">
            ${stage.label}
          </div>
        `).join("")}
      </div>
      <div class="sd-timeline-meta">
        <div><strong>First seen:</strong> ${timeAgo(incident.createdAt)}</div>
        <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
        <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
        <div><strong>Pattern state:</strong> ${getEscalationLabel(incident)}</div>
      </div>
    </div>
  `;
}

// =======================
// PATCH renderIncidents AGAIN
// =======================

renderIncidents = function(items = []) {
  if (!incidentList) return;

  if (!items.length) {
    incidentList.innerHTML = `
