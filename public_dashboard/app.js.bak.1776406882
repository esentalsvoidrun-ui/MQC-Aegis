      box-shadow: 0 6px 16px rgba(0,0,0,0.18);
    }

    .sd-btn-assign {
      background: rgba(120,160,255,0.14);
      border-color: rgba(120,160,255,0.28);
    }

    .sd-btn-ack {
      background: rgba(255,190,80,0.14);
