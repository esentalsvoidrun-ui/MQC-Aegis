// =======================
// INCIDENT FILTERS
// =======================

const incidentFilterState = {
  status: "all",
  recurringOnly: false,
  criticalOnly: false
};

(function injectFilterStyles() {
  if (document.getElementById("sd-filter-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-filter-styles";
  style.textContent = `
    .sd-filter-bar {
      display: grid;
      gap: 10px;
      margin-bottom: 14px;
      padding: 12px;
      border-radius: 14px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .sd-filter-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .sd-filter-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.68;
      min-width: 54px;
    }

    .sd-filter-chip {
      appearance: none;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.05);
      color: #eef4ff;
      border-radius: 999px;
      padding: 7px 10px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
    }

    .sd-filter-chip.active {
      background: rgba(120,160,255,0.18);
      border-color: rgba(120,160,255,0.32);
    }

    .sd-filter-toggle {
      appearance: none;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.05);
      color: #eef4ff;
      border-radius: 10px;
      padding: 8px 10px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
    }

    .sd-filter-toggle.active {
      background: rgba(177,120,255,0.18);
      border-color: rgba(177,120,255,0.34);
    }

    .sd-filter-summary {
      font-size: 12px;
      opacity: 0.76;
    }
  `;
  document.head.appendChild(style);
})();

function setIncidentStatusFilter(status) {
  incidentFilterState.status = status;
  refreshAll();
}

function toggleRecurringOnly() {
  incidentFilterState.recurringOnly = !incidentFilterState.recurringOnly;
  refreshAll();
}

function toggleCriticalOnly() {
  incidentFilterState.criticalOnly = !incidentFilterState.criticalOnly;
  refreshAll();
}

function applyIncidentFilters(items = []) {
  return items.filter((incident) => {
    const status = String(incident.status || "pending_review");
    const repeatCount = incident.repeatCount || 1;
    const severity = String(incident.severity || "low");

    if (incidentFilterState.status !== "all" && status !== incidentFilterState.status) {
      return false;
    }

    if (incidentFilterState.recurringOnly && repeatCount < 2) {
      return false;
    }

    if (incidentFilterState.criticalOnly && severity !== "critical") {
      return false;
    }

    return true;
  });
}

function renderIncidentFilterBar(allItems = [], filteredItems = []) {
  return `
    <div class="sd-filter-bar">
      <div class="sd-filter-row">
        <div class="sd-filter-label">Status</div>

        <button class="sd-filter-chip ${incidentFilterState.status === "all" ? "active" : ""}"
          onclick="setIncidentStatusFilter('all')">All</button>

        <button class="sd-filter-chip ${incidentFilterState.status === "pending_review" ? "active" : ""}"
          onclick="setIncidentStatusFilter('pending_review')">Open</button>

        <button class="sd-filter-chip ${incidentFilterState.status === "acknowledged" ? "active" : ""}"
          onclick="setIncidentStatusFilter('acknowledged')">Acknowledged</button>

        <button class="sd-filter-chip ${incidentFilterState.status === "resolved" ? "active" : ""}"
          onclick="setIncidentStatusFilter('resolved')">Resolved</button>
      </div>

      <div class="sd-filter-row">
        <button class="sd-filter-toggle ${incidentFilterState.recurringOnly ? "active" : ""}"
          onclick="toggleRecurringOnly()">
          Recurring only
        </button>

        <button class="sd-filter-toggle ${incidentFilterState.criticalOnly ? "active" : ""}"
          onclick="toggleCriticalOnly()">
          Critical only
        </button>
      </div>

      <div class="sd-filter-summary">
        Showing ${filteredItems.length} of ${allItems.length} incidents
      </div>
    </div>
  `;
}

window.setIncidentStatusFilter = setIncidentStatusFilter;
window.toggleRecurringOnly = toggleRecurringOnly;
window.toggleCriticalOnly = toggleCriticalOnly;

// =======================
// PATCH renderIncidents WITH FILTERS
// =======================

renderIncidents = function(items = []) {
  if (!incidentList) return;

  const filteredItems = applyIncidentFilters(items);

  if (!items.length) {
    incidentList.innerHTML = `
      ${renderIncidentFilterBar(items, filteredItems)}
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents yet</div>
        <div class="sd-empty-sub">The watch floor is quiet. Enjoy it while it lasts.</div>
      </div>
    `;
    return;
  }

  if (!filteredItems.length) {
    incidentList.innerHTML = `
      ${renderIncidentFilterBar(items, filteredItems)}
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents match the current filter</div>
        <div class="sd-empty-sub">Try widening the net. Even old sea captains did not inspect the whole ocean through a keyhole.</div>
      </div>
    `;
    return;
  }

  incidentList.innerHTML =
    renderIncidentFilterBar(items, filteredItems) +
    filteredItems.map((incident) => {
      const repeatCount = incident.repeatCount || 1;
      const pressure = getPressureLevel(incident);
      const fresh = isFresh(incident.lastSeenAt);
      const rawStatus = String(incident.status || "pending_review");
      const status = escapeHtml(rawStatus);
      const buttonState = getButtonState(incident);

      const repeatBadgeClass =
        repeatCount >= 5 ? "sd-badge sd-badge-hot" :
        repeatCount >= 3 ? "sd-badge sev-high" :
        repeatCount >= 2 ? "sd-badge sd-badge-recurring" :
        "sd-badge";

      const repeatBadge = `
        <span class="${repeatBadgeClass}">
          ${repeatCount > 1 ? `Recurring x${repeatCount}` : "First seen"}
        </span>
      `;

      const freshnessDot = fresh ? `<span class="fresh-dot"></span>` : "";

      return `
        <div class="sd-card incident-card ${pressure}">
          <div class="sd-card-header">
            <div>
              <div class="sd-eyebrow">
                Incident #${incident.id} ${freshnessDot}
              </div>
              <div class="sd-title">
                ${escapeHtml(incident.type)} · ${escapeHtml(incident.user)}
              </div>
            </div>

            <div class="sd-badge-row">
              <span class="sd-badge ${severityClass(incident.severity)}">
                ${escapeHtml((incident.severity || "low").toUpperCase())}
              </span>

              <span class="sd-badge sd-badge-action">
                ${escapeHtml(actionLabel(incident.action))}
              </span>

              ${repeatBadge}
            </div>
          </div>

          <div class="sd-meta-row">
            <div><strong>Risk:</strong> ${incident.riskScore}</div>
            <div><strong>Status:</strong> <span class="sd-status-pill ${status}">${status}</span></div>
            <div><strong>SLA:</strong> ${escapeHtml(incident.sla)}</div>
            <div><strong>Repeats:</strong> ${repeatCount}</div>
          </div>

          <div class="sd-meta-row">
            <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
            <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
            <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
            <div><strong>Assigned:</strong> ${escapeHtml(incident.assignedTo || "unassigned")}</div>
          </div>

          <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
            ${repeatCount > 1 ? `Pattern repeating (${repeatCount}x)` : "Single occurrence"}
          </div>

          <div class="sd-chip-row">
            ${(incident.reasonCodes || [])
              .map(r => `<span class="sd-chip">${escapeHtml(r)}</span>`)
              .join("")}
          </div>

          ${renderTimeline(incident)}
          ${renderCaseHistory(incident)}

          <div class="sd-operator-bar">
            <div class="sd-operator-row">
              <input
                id="operator-input-${incident.id}"
                class="sd-operator-input"
                type="text"
                placeholder="Operator name"
                value="${escapeHtml(incident.assignedTo || incident.lastOperator || "Robert")}"
              />
            </div>

            <div class="sd-operator-actions">
              <button
                class="sd-btn sd-btn-assign"
                onclick="assignIncident(${incident.id})"
                ${buttonState.assignDisabled ? "disabled" : ""}
              >
                ${buttonState.assignLabel}
              </button>

              <button
                class="sd-btn sd-btn-ack"
                onclick="acknowledgeIncident(${incident.id})"
                ${buttonState.ackDisabled ? "disabled" : ""}
              >
                ${buttonState.ackLabel}
              </button>

              <button
                class="sd-btn sd-btn-resolve"
                onclick="resolveIncident(${incident.id})"
                ${buttonState.resolveDisabled ? "disabled" : ""}
              >
                ${buttonState.resolveLabel}
              </button>
            </div>

            <div class="sd-operator-meta">
              <span><strong>Last operator:</strong> ${escapeHtml(incident.lastOperator || "none")}</span>
            </div>

            <div id="operator-feedback-${incident.id}"></div>
          </div>
        </div>
      `;
    }).join("");

  filteredItems.forEach((incident) => renderOperatorFeedback(incident.id));
};


// =======================
// INCIDENT SORTING
// =======================

incidentFilterState.sortBy = "updated";

(function injectSortStyles() {
  if (document.getElementById("sd-sort-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-sort-styles";
  style.textContent = `
    .sd-sort-select {
      appearance: none;
      background: rgba(255,255,255,0.05);
      color: #eef4ff;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 8px 10px;
      font-size: 11px;
      font-weight: 700;
      min-width: 170px;
    }
  `;
  document.head.appendChild(style);
})();

function setIncidentSort(sortBy) {
  incidentFilterState.sortBy = sortBy;
  refreshAll();
}

function sortIncidents(items = []) {
  const arr = [...items];
  const sortBy = incidentFilterState.sortBy || "updated";

  if (sortBy === "risk") {
    arr.sort((a, b) => (b.riskScore || 0) - (a.riskScore || 0));
    return arr;
  }

  if (sortBy === "repeats") {
    arr.sort((a, b) => {
      const repeatDiff = (b.repeatCount || 1) - (a.repeatCount || 1);
      if (repeatDiff !== 0) return repeatDiff;
      return new Date(b.updatedAt || 0).getTime() - new Date(a.updatedAt || 0).getTime();
    });
    return arr;
  }

  // default: updated
  arr.sort((a, b) => new Date(b.updatedAt || 0).getTime() - new Date(a.updatedAt || 0).getTime());
  return arr;
}

window.setIncidentSort = setIncidentSort;

// =======================
// PATCH renderIncidentFilterBar WITH SORT
// =======================

renderIncidentFilterBar = function(allItems = [], filteredItems = []) {
  return `
    <div class="sd-filter-bar">
      <div class="sd-filter-row">
        <div class="sd-filter-label">Status</div>

        <button class="sd-filter-chip ${incidentFilterState.status === "all" ? "active" : ""}"
          onclick="setIncidentStatusFilter('all')">All</button>

        <button class="sd-filter-chip ${incidentFilterState.status === "pending_review" ? "active" : ""}"
          onclick="setIncidentStatusFilter('pending_review')">Open</button>

        <button class="sd-filter-chip ${incidentFilterState.status === "acknowledged" ? "active" : ""}"
          onclick="setIncidentStatusFilter('acknowledged')">Acknowledged</button>

        <button class="sd-filter-chip ${incidentFilterState.status === "resolved" ? "active" : ""}"
          onclick="setIncidentStatusFilter('resolved')">Resolved</button>
      </div>

      <div class="sd-filter-row">
        <button class="sd-filter-toggle ${incidentFilterState.recurringOnly ? "active" : ""}"
          onclick="toggleRecurringOnly()">
          Recurring only
        </button>

        <button class="sd-filter-toggle ${incidentFilterState.criticalOnly ? "active" : ""}"
          onclick="toggleCriticalOnly()">
          Critical only
        </button>
      </div>

      <div class="sd-filter-row">
        <div class="sd-filter-label">Sort</div>
        <select class="sd-sort-select" onchange="setIncidentSort(this.value)">
          <option value="updated" ${incidentFilterState.sortBy === "updated" ? "selected" : ""}>Newest updated</option>
          <option value="risk" ${incidentFilterState.sortBy === "risk" ? "selected" : ""}>Highest risk</option>
          <option value="repeats" ${incidentFilterState.sortBy === "repeats" ? "selected" : ""}>Most repeats</option>
        </select>
      </div>

      <div class="sd-filter-summary">
        Showing ${filteredItems.length} of ${allItems.length} incidents
      </div>
    </div>
  `;
};

// =======================
// PATCH renderIncidents WITH SORTED ITEMS
// =======================

renderIncidents = function(items = []) {
  if (!incidentList) return;

  const filteredItems = applyIncidentFilters(items);
  const visibleItems = sortIncidents(filteredItems);

  if (!items.length) {
    incidentList.innerHTML = `
      ${renderIncidentFilterBar(items, visibleItems)}
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents yet</div>
        <div class="sd-empty-sub">The watch floor is quiet. Enjoy it while it lasts.</div>
      </div>
    `;
    return;
  }

  if (!visibleItems.length) {
    incidentList.innerHTML = `
      ${renderIncidentFilterBar(items, visibleItems)}
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents match the current filter</div>
        <div class="sd-empty-sub">Try widening the net. Even old sea captains did not inspect the whole ocean through a keyhole.</div>
      </div>
    `;
    return;
  }

  incidentList.innerHTML =
    renderIncidentFilterBar(items, visibleItems) +
    visibleItems.map((incident) => {
      const repeatCount = incident.repeatCount || 1;
      const pressure = getPressureLevel(incident);
      const fresh = isFresh(incident.lastSeenAt);
      const rawStatus = String(incident.status || "pending_review");
      const status = escapeHtml(rawStatus);
      const buttonState = getButtonState(incident);

      const repeatBadgeClass =
        repeatCount >= 5 ? "sd-badge sd-badge-hot" :
        repeatCount >= 3 ? "sd-badge sev-high" :
        repeatCount >= 2 ? "sd-badge sd-badge-recurring" :
        "sd-badge";

      const repeatBadge = `
        <span class="${repeatBadgeClass}">
          ${repeatCount > 1 ? `Recurring x${repeatCount}` : "First seen"}
        </span>
      `;

      const freshnessDot = fresh ? `<span class="fresh-dot"></span>` : "";

      return `
        <div class="sd-card incident-card ${pressure}">
          <div class="sd-card-header">
            <div>
              <div class="sd-eyebrow">
                Incident #${incident.id} ${freshnessDot}
              </div>
              <div class="sd-title">
                ${escapeHtml(incident.type)} · ${escapeHtml(incident.user)}
              </div>
            </div>

            <div class="sd-badge-row">
              <span class="sd-badge ${severityClass(incident.severity)}">
                ${escapeHtml((incident.severity || "low").toUpperCase())}
              </span>

              <span class="sd-badge sd-badge-action">
                ${escapeHtml(actionLabel(incident.action))}
              </span>

              ${repeatBadge}
            </div>
          </div>

          <div class="sd-meta-row">
            <div><strong>Risk:</strong> ${incident.riskScore}</div>
            <div><strong>Status:</strong> <span class="sd-status-pill ${status}">${status}</span></div>
            <div><strong>SLA:</strong> ${escapeHtml(incident.sla)}</div>
            <div><strong>Repeats:</strong> ${repeatCount}</div>
          </div>

          <div class="sd-meta-row">
            <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
            <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
            <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
            <div><strong>Assigned:</strong> ${escapeHtml(incident.assignedTo || "unassigned")}</div>
          </div>

          <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
            ${repeatCount > 1 ? `Pattern repeating (${repeatCount}x)` : "Single occurrence"}
          </div>

          <div class="sd-chip-row">
            ${(incident.reasonCodes || [])
              .map(r => `<span class="sd-chip">${escapeHtml(r)}</span>`)
              .join("")}
          </div>

          ${renderTimeline(incident)}
          ${renderCaseHistory(incident)}

          <div class="sd-operator-bar">
            <div class="sd-operator-row">
              <input
                id="operator-input-${incident.id}"
                class="sd-operator-input"
                type="text"
                placeholder="Operator name"
                value="${escapeHtml(incident.assignedTo || incident.lastOperator || "Robert")}"
              />
            </div>

            <div class="sd-operator-actions">
              <button
                class="sd-btn sd-btn-assign"
                onclick="assignIncident(${incident.id})"
                ${buttonState.assignDisabled ? "disabled" : ""}
              >
                ${buttonState.assignLabel}
              </button>

              <button
                class="sd-btn sd-btn-ack"
                onclick="acknowledgeIncident(${incident.id})"
                ${buttonState.ackDisabled ? "disabled" : ""}
              >
                ${buttonState.ackLabel}
              </button>

              <button
                class="sd-btn sd-btn-resolve"
                onclick="resolveIncident(${incident.id})"
                ${buttonState.resolveDisabled ? "disabled" : ""}
              >
                ${buttonState.resolveLabel}
              </button>
            </div>

            <div class="sd-operator-meta">
              <span><strong>Last operator:</strong> ${escapeHtml(incident.lastOperator || "none")}</span>
            </div>

            <div id="operator-feedback-${incident.id}"></div>
          </div>
        </div>
      `;
    }).join("");

  visibleItems.forEach((incident) => renderOperatorFeedback(incident.id));
};


