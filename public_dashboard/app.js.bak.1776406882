      border-radius: 10px;
      padding: 9px 8px;
      font-size: 11px;
      font-weight: 700;
      cursor: pointer;
      transition: transform 120ms ease, box-shadow 120ms ease, background 120ms ease;
    }

    .sd-btn:hover {
