          <div><strong>Assigned:</strong> ${escapeHtml(incident.assignedTo || "unassigned")}</div>
        </div>

        <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
          ${repeatCount > 1 ? `Pattern repeating (${repeatCount}x)` : "Single occurrence"}
        </div>

        <div class="sd-chip-row">
          ${(incident.reasonCodes || [])
            .map(r => `<span class="sd-chip">${escapeHtml(r)}</span>`)
            .join("")}
        </div>

        ${renderTimeline(incident)}
        ${renderCaseHistory(incident)}

        <div class="sd-operator-bar">
          <div class="sd-operator-row">
            <input
              id="operator-input-${incident.id}"
              class="sd-operator-input"
              type="text"
              placeholder="Operator name"
              value="${escapeHtml(incident.assignedTo || incident.lastOperator || "Robert")}"
            />
          </div>

          <div class="sd-operator-actions">
            <button class="sd-btn sd-btn-assign" onclick="assignIncident(${incident.id})">Assign</button>
            <button class="sd-btn sd-btn-ack" onclick="acknowledgeIncident(${incident.id})">Acknowledge</button>
            <button class="sd-btn sd-btn-resolve" onclick="resolveIncident(${incident.id})">Resolve</button>
          </div>

          <div class="sd-operator-meta">
            <span><strong>Last operator:</strong> ${escapeHtml(incident.lastOperator || "none")}</span>
          </div>
        </div>
      </div>
    `;
  }).join("");
};

window.assignIncident = assignIncident;
window.acknowledgeIncident = acknowledgeIncident;
window.resolveIncident = resolveIncident;


// =======================
// STATUS-SMART BUTTON LOGIC
// =======================

(function injectSmartButtonStyles() {
  if (document.getElementById("sd-smart-button-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-smart-button-styles";
  style.textContent = `
    .sd-btn[disabled] {
      opacity: 0.38;
      cursor: not-allowed;
      transform: none !important;
      box-shadow: none !important;
      filter: grayscale(0.2);
    }

    .sd-btn[disabled]:hover {
      transform: none !important;
      box-shadow: none !important;
    }

    .sd-status-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.1);
    }

    .sd-status-pill.pending_review {
      background: rgba(255,255,255,0.07);
    }

    .sd-status-pill.acknowledged {
      background: rgba(255,190,80,0.16);
      border-color: rgba(255,190,80,0.28);
    }

    .sd-status-pill.resolved {
      background: rgba(60,210,140,0.16);
      border-color: rgba(60,210,140,0.30);
    }
  `;
  document.head.appendChild(style);
})();

function normalizeOperatorName(value) {
  return String(value || "").trim().toLowerCase();
}

function getButtonState(incident) {
  const status = String(incident.status || "pending_review");
  const inputValue = getOperatorValue(incident.id) || incident.assignedTo || incident.lastOperator || "Robert";

  const assignedToSameOperator =
    incident.assignedTo &&
    normalizeOperatorName(incident.assignedTo) === normalizeOperatorName(inputValue);

  const assignDisabled = status === "resolved" || !!assignedToSameOperator;
  const ackDisabled = status === "acknowledged" || status === "resolved";
  const resolveDisabled = status === "resolved";

  const assignLabel =
    status === "resolved"
      ? "Assigned"
      : assignedToSameOperator
      ? "Assigned"
      : "Assign";

  const ackLabel =
    status === "resolved"
      ? "Acknowledged"
      : status === "acknowledged"
      ? "Acknowledged"
      : "Acknowledge";

  const resolveLabel =
    status === "resolved"
      ? "Resolved"
      : "Resolve";

  return {
    assignDisabled,
    ackDisabled,
    resolveDisabled,
    assignLabel,
    ackLabel,
    resolveLabel
  };
}

// =======================
// PATCH renderIncidents WITH SMART BUTTONS
// =======================

renderIncidents = function(items = []) {
  if (!incidentList) return;

  if (!items.length) {
    incidentList.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents yet</div>
        <div class="sd-empty-sub">The watch floor is quiet. Enjoy it while it lasts.</div>
      </div>
    `;
    return;
  }

  incidentList.innerHTML = items.map((incident) => {
    const repeatCount = incident.repeatCount || 1;
    const pressure = getPressureLevel(incident);
    const fresh = isFresh(incident.lastSeenAt);
    const status = escapeHtml(incident.status || "pending_review");
    const buttonState = getButtonState(incident);

    const repeatBadgeClass =
      repeatCount >= 5 ? "sd-badge sd-badge-hot" :
      repeatCount >= 3 ? "sd-badge sev-high" :
      repeatCount >= 2 ? "sd-badge sd-badge-recurring" :
      "sd-badge";

    const repeatBadge = `
      <span class="${repeatBadgeClass}">
        ${repeatCount > 1 ? `Recurring x${repeatCount}` : "First seen"}
      </span>
    `;

    const freshnessDot = fresh ? `<span class="fresh-dot"></span>` : "";

    return `
      <div class="sd-card incident-card ${pressure}">
        <div class="sd-card-header">
          <div>
            <div class="sd-eyebrow">
              Incident #${incident.id} ${freshnessDot}
            </div>
            <div class="sd-title">
              ${escapeHtml(incident.type)} · ${escapeHtml(incident.user)}
            </div>
          </div>

          <div class="sd-badge-row">
            <span class="sd-badge ${severityClass(incident.severity)}">
              ${escapeHtml((incident.severity || "low").toUpperCase())}
            </span>

            <span class="sd-badge sd-badge-action">
              ${escapeHtml(actionLabel(incident.action))}
            </span>

            ${repeatBadge}
          </div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Risk:</strong> ${incident.riskScore}</div>
          <div><strong>Status:</strong> <span class="sd-status-pill ${status}">${status}</span></div>
          <div><strong>SLA:</strong> ${escapeHtml(incident.sla)}</div>
          <div><strong>Repeats:</strong> ${repeatCount}</div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
          <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
          <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
          <div><strong>Assigned:</strong> ${escapeHtml(incident.assignedTo || "unassigned")}</div>
        </div>

        <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
          ${repeatCount > 1 ? `Pattern repeating (${repeatCount}x)` : "Single occurrence"}
        </div>

        <div class="sd-chip-row">
          ${(incident.reasonCodes || [])
            .map(r => `<span class="sd-chip">${escapeHtml(r)}</span>`)
            .join("")}
        </div>

        ${renderTimeline(incident)}
        ${renderCaseHistory(incident)}

        <div class="sd-operator-bar">
          <div class="sd-operator-row">
            <input
              id="operator-input-${incident.id}"
              class="sd-operator-input"
              type="text"
              placeholder="Operator name"
              value="${escapeHtml(incident.assignedTo || incident.lastOperator || "Robert")}"
            />
          </div>

          <div class="sd-operator-actions">
            <button
              class="sd-btn sd-btn-assign"
              onclick="assignIncident(${incident.id})"
              ${buttonState.assignDisabled ? "disabled" : ""}
            >
              ${buttonState.assignLabel}
            </button>

            <button
              class="sd-btn sd-btn-ack"
              onclick="acknowledgeIncident(${incident.id})"
              ${buttonState.ackDisabled ? "disabled" : ""}
            >
              ${buttonState.ackLabel}
            </button>

            <button
              class="sd-btn sd-btn-resolve"
              onclick="resolveIncident(${incident.id})"
              ${buttonState.resolveDisabled ? "disabled" : ""}
            >
              ${buttonState.resolveLabel}
            </button>
          </div>

          <div class="sd-operator-meta">
            <span><strong>Last operator:</strong> ${escapeHtml(incident.lastOperator || "none")}</span>
          </div>
        </div>
      </div>
    `;
  }).join("");
};


// =======================
// OPERATOR FEEDBACK / TOAST-LITE
// =======================

const operatorFeedbackStore = new Map();

function setOperatorFeedback(incidentId, message, type = "info") {
  operatorFeedbackStore.set(String(incidentId), {
    message,
    type,
    at: Date.now()
  });

  renderOperatorFeedback(incidentId);

  setTimeout(() => {
    const current = operatorFeedbackStore.get(String(incidentId));
    if (current && Date.now() - current.at >= 3500) {
      operatorFeedbackStore.delete(String(incidentId));
      renderOperatorFeedback(incidentId);
    }
  }, 3600);
}

function getOperatorFeedback(incidentId) {
  return operatorFeedbackStore.get(String(incidentId)) || null;
}

function renderOperatorFeedback(incidentId) {
  const el = document.getElementById(`operator-feedback-${incidentId}`);
  if (!el) return;

  const feedback = getOperatorFeedback(incidentId);
  if (!feedback) {
    el.innerHTML = "";
    return;
  }

  el.innerHTML = `
    <div class="sd-feedback sd-feedback-${feedback.type}">
      ${escapeHtml(feedback.message)}
    </div>
  `;
}

(function injectOperatorFeedbackStyles() {
  if (document.getElementById("sd-operator-feedback-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-operator-feedback-styles";
  style.textContent = `
    .sd-feedback {
      margin-top: 8px;
      border-radius: 10px;
      padding: 8px 10px;
      font-size: 12px;
      font-weight: 600;
      border: 1px solid rgba(255,255,255,0.12);
      background: rgba(255,255,255,0.05);
    }

    .sd-feedback-info {
      background: rgba(120,160,255,0.12);
      border-color: rgba(120,160,255,0.22);
    }

    .sd-feedback-success {
      background: rgba(60,210,140,0.14);
      border-color: rgba(60,210,140,0.28);
    }

    .sd-feedback-error {
      background: rgba(255,90,90,0.14);
      border-color: rgba(255,90,90,0.32);
    }
  `;
  document.head.appendChild(style);
})();

// =======================
// PATCH ACTION FUNCTIONS WITH FEEDBACK
// =======================

assignIncident = async function(incidentId) {
  try {
    const assignedTo = getOperatorValue(incidentId) || "Robert";
    await postJson(`/api/incidents/${incidentId}/assign`, { assignedTo });
    setOperatorFeedback(incidentId, `Assigned to ${assignedTo}.`, "success");
    await refreshAll();
  } catch (error) {
    console.error("assignIncident failed", error);
    setOperatorFeedback(incidentId, `Assign failed: ${error.message}`, "error");
  }
};

acknowledgeIncident = async function(incidentId) {
  try {
    const operator = getOperatorValue(incidentId) || "Robert";
    await postJson(`/api/incidents/${incidentId}/acknowledge`, {
      operator,
      note: "Acknowledged from UI"
    });
    setOperatorFeedback(incidentId, `Acknowledged by ${operator}.`, "success");
    await refreshAll();
  } catch (error) {
    console.error("acknowledgeIncident failed", error);
    setOperatorFeedback(incidentId, `Acknowledge failed: ${error.message}`, "error");
  }
};

resolveIncident = async function(incidentId) {
  try {
    const operator = getOperatorValue(incidentId) || "Robert";
    await postJson(`/api/incidents/${incidentId}/resolve`, {
      operator,
      resolution: "Resolved from UI"
    });
    setOperatorFeedback(incidentId, `Resolved by ${operator}.`, "success");
    await refreshAll();
  } catch (error) {
    console.error("resolveIncident failed", error);
    setOperatorFeedback(incidentId, `Resolve failed: ${error.message}`, "error");
  }
};

window.assignIncident = assignIncident;
window.acknowledgeIncident = acknowledgeIncident;
window.resolveIncident = resolveIncident;

