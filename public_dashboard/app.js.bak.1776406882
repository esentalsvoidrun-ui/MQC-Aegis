(function injectWideGridStyles() {
  if (document.getElementById("sd-wide-grid-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-wide-grid-styles";
  style.textContent = `
    .sd-incident-shell {
      width: 100%;
      display: grid;
      gap: 14px;
      align-items: start;
    }

    .sd-incident-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
      align-items: start;
    }

    @media (min-width: 1100px) {
      .sd-incident-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 1680px) {
      .sd-incident-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .incident-card {
      width: 100%;
      min-width: 0;
      align-self: start;
    }

    .sd-filter-bar {
      position: sticky;
      top: 8px;
      z-index: 3;
      backdrop-filter: blur(6px);
    }

    .sd-card,
    .sd-meta-row,
    .sd-chip-row,
    .sd-operator-actions,
    .sd-timeline-track,
    .sd-timeline-meta,
    .sd-history-list {
      min-width: 0;
    }

    .sd-title,
    .sd-history-text,
    .sd-summary-text,
    .sd-summary-rec,
    .sd-note {
      word-break: break-word;
      overflow-wrap: anywhere;
    }

    .sd-chip {
      max-width: 100%;
      overflow-wrap: anywhere;
    }

    .sd-operator-actions {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .sd-filter-row {
      justify-content: flex-start;
    }
  `;
  document.head.appendChild(style);
})();

// =======================
