  incidentList.innerHTML = items.map((incident) => {
    const repeatCount = incident.repeatCount || 1;
    const pressure = getPressureLevel(incident);
    const fresh = isFresh(incident.lastSeenAt);

    const repeatBadgeClass =
      repeatCount >= 5 ? "sd-badge sd-badge-hot" :
      repeatCount >= 3 ? "sd-badge sev-high" :
      repeatCount >= 2 ? "sd-badge sd-badge-recurring" :
      "sd-badge";

    const repeatBadge = `
      <span class="${repeatBadgeClass}">
        ${repeatCount > 1 ? `Recurring x${repeatCount}` : "First seen"}
      </span>
    `;

    const freshnessDot = fresh ? `<span class="fresh-dot"></span>` : "";

    return `
      <div class="sd-card incident-card ${pressure}">
        <div class="sd-card-header">
          <div>
            <div class="sd-eyebrow">
              Incident #${incident.id} ${freshnessDot}
            </div>
            <div class="sd-title">
              ${incident.type} · ${incident.user}
            </div>
          </div>

          <div class="sd-badge-row">
            <span class="sd-badge ${severityClass(incident.severity)}">
              ${incident.severity.toUpperCase()}
            </span>

            <span class="sd-badge sd-badge-action">
              ${actionLabel(incident.action)}
            </span>

            ${repeatBadge}
          </div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Risk:</strong> ${incident.riskScore}</div>
          <div><strong>Status:</strong> ${incident.status}</div>
          <div><strong>SLA:</strong> ${incident.sla}</div>
          <div><strong>Repeats:</strong> ${repeatCount}</div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
          <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
          <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
        </div>

        <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
          ${repeatCount > 1 ? `Pattern repeating (${repeatCount}x)` : "Single occurrence"}
        </div>

        <div class="sd-chip-row">
          ${(incident.reasonCodes || [])
            .map(r => `<span class="sd-chip">${r}</span>`)
            .join("")}
        </div>

        ${renderTimeline(incident)}
      </div>
    `;
  }).join("");
};


// =======================
// CASE MEMORY / BLACK BOX
// =======================

(function injectBlackBoxStyles() {
  if (document.getElementById("sd-blackbox-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-blackbox-styles";
  style.textContent = `
    .sd-blackbox {
      margin-top: 12px;
      padding-top: 10px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .sd-blackbox-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      opacity: 0.68;
      margin-bottom: 8px;
    }

    .sd-history-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .sd-history-item {
      display: grid;
      grid-template-columns: 90px 1fr;
      gap: 10px;
      align-items: start;
      padding: 8px 10px;
      border-radius: 10px;
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.06);
      font-size: 12px;
    }

    .sd-history-time {
      opacity: 0.65;
      font-weight: 600;
      white-space: nowrap;
    }

    .sd-history-text {
      line-height: 1.35;
      opacity: 0.95;
    }

    .sd-history-item.hot {
      border-color: rgba(255,166,0,0.26);
      background: rgba(255,166,0,0.06);
    }

    .sd-history-item.critical {
      border-color: rgba(255,70,70,0.34);
      background: rgba(255,70,70,0.08);
    }
  `;
  document.head.appendChild(style);
})();

function mapAuditTypeToText(entry, incident) {
  const details = entry.details || {};

  if (entry.type === "opened") {
    return {
      text: `Case opened as ${details.severity || incident.severity} with action "${actionLabel(details.action || incident.action)}".`,
      cls: ""
    };
  }

  if (entry.type === "merged") {
    return {
      text: `Merged again. Pattern repeated ${details.repeatCountTo || incident.repeatCount || 1} times.`,
      cls: (details.repeatCountTo || 1) >= 5 ? "critical" : "hot"
    };
  }

  if (entry.type === "severity_changed") {
    return {
      text: `Severity changed from ${details.from} to ${details.to}.`,
      cls: "hot"
    };
  }

  if (entry.type === "risk_score_raised") {
    return {
      text: `Risk score increased from ${details.from} to ${details.to}.`,
      cls: "hot"
    };
  }

  if (entry.type === "reason_codes_expanded") {
    return {
      text: `Reason set expanded: ${(details.added || []).join(", ")}.`,
      cls: ""
    };
  }

  if (entry.type === "correlation_detected") {
    return {
      text: `Correlation detected: ${details.label}.`,
      cls: "hot"
    };
  }

  if (entry.type === "trend_detected") {
    return {
      text: `Trend anomaly active: ${details.label}.`,
      cls: ""
    };
  }

  if (entry.type === "action_created") {
    return {
      text: `Action created: ${details.title || details.actionType || "action"}.`,
      cls: ""
    };
  }

  if (entry.type === "assigned") {
    return {
      text: `Assigned to ${details.to}${details.from ? ` from ${details.from}` : ""}.`,
      cls: ""
    };
  }

  if (entry.type === "acknowledged") {
    return {
      text: `Acknowledged by ${details.operator || "operator"}${details.note ? ` · ${details.note}` : ""}.`,
      cls: "hot"
    };
  }

  if (entry.type === "resolved") {
    return {
      text: `Resolved by ${details.operator || "operator"}${details.resolution ? ` · ${details.resolution}` : ""}.`,
      cls: "critical"
    };
  }

  return {
    text: entry.type,
    cls: ""
  };
}

function buildCaseHistory(incident) {
  if (Array.isArray(incident.auditTrail) && incident.auditTrail.length) {
    return incident.auditTrail.map((entry) => {
      const mapped = mapAuditTypeToText(entry, incident);
      return {
        time: timeAgo(entry.at),
        text: mapped.text,
        cls: mapped.cls
      };
    });
  }

  const history = [];
  const repeatCount = incident.repeatCount || 1;

  history.push({
    time: timeAgo(incident.createdAt),
    text: `Case opened as ${incident.severity} with action "${actionLabel(incident.action)}".`,
    cls: ""
  });

  if (repeatCount >= 2) {
    history.push({
      time: timeAgo(incident.lastSeenAt),
      text: `Merged again. Pattern repeated ${repeatCount} times.`,
      cls: repeatCount >= 5 ? "critical" : "hot"
    });
  }

  return history;
}

function renderCaseHistory(incident) {
  const history = buildCaseHistory(incident);

  return `
    <div class="sd-blackbox">
      <div class="sd-blackbox-title">Case memory</div>
      <div class="sd-history-list">
        ${history.map(item => `
          <div class="sd-history-item ${item.cls}">
            <div class="sd-history-time">${item.time}</div>
            <div class="sd-history-text">${item.text}</div>
          </div>
        `).join("")}
      </div>
    </div>
  `;
}

// =======================
// PATCH renderIncidents AGAIN
// =======================

renderIncidents = function(items = []) {
  if (!incidentList) return;

  if (!items.length) {
    incidentList.innerHTML = `
      <div class="sd-empty">
        <div class="sd-empty-title">No incidents yet</div>
        <div class="sd-empty-sub">The watch floor is quiet. Enjoy it while it lasts.</div>
      </div>
    `;
    return;
  }

  incidentList.innerHTML = items.map((incident) => {
    const repeatCount = incident.repeatCount || 1;
    const pressure = getPressureLevel(incident);
    const fresh = isFresh(incident.lastSeenAt);

    const repeatBadgeClass =
      repeatCount >= 5 ? "sd-badge sd-badge-hot" :
      repeatCount >= 3 ? "sd-badge sev-high" :
      repeatCount >= 2 ? "sd-badge sd-badge-recurring" :
      "sd-badge";

    const repeatBadge = `
      <span class="${repeatBadgeClass}">
        ${repeatCount > 1 ? `Recurring x${repeatCount}` : "First seen"}
      </span>
    `;

    const freshnessDot = fresh ? `<span class="fresh-dot"></span>` : "";

    return `
      <div class="sd-card incident-card ${pressure}">
        <div class="sd-card-header">
          <div>
            <div class="sd-eyebrow">
              Incident #${incident.id} ${freshnessDot}
            </div>
            <div class="sd-title">
              ${incident.type} · ${incident.user}
            </div>
          </div>

          <div class="sd-badge-row">
            <span class="sd-badge ${severityClass(incident.severity)}">
              ${incident.severity.toUpperCase()}
            </span>

            <span class="sd-badge sd-badge-action">
              ${actionLabel(incident.action)}
            </span>

            ${repeatBadge}
          </div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Risk:</strong> ${incident.riskScore}</div>
          <div><strong>Status:</strong> ${incident.status}</div>
          <div><strong>SLA:</strong> ${incident.sla}</div>
          <div><strong>Repeats:</strong> ${repeatCount}</div>
        </div>

        <div class="sd-meta-row">
          <div><strong>Created:</strong> ${timeAgo(incident.createdAt)}</div>
          <div><strong>Updated:</strong> ${timeAgo(incident.updatedAt)}</div>
          <div><strong>Last seen:</strong> ${timeAgo(incident.lastSeenAt)}</div>
        </div>

        <div class="sd-pressure ${pressure !== "normal" ? "sd-pressure-hot" : ""}">
          ${repeatCount > 1 ? `Pattern repeating (${repeatCount}x)` : "Single occurrence"}
        </div>

        <div class="sd-chip-row">
          ${(incident.reasonCodes || [])
            .map(r => `<span class="sd-chip">${r}</span>`)
            .join("")}
        </div>

        ${renderTimeline(incident)}
        ${renderCaseHistory(incident)}
      </div>
    `;
  }).join("");
};


// =======================
// OPERATOR ACTIONS
// =======================

async function postJson(path, payload) {
  const res = await fetch(`${apiBase}${path}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify(payload || {})
  });

  if (!res.ok) {
    let message = `HTTP ${res.status}`;
    try {
      const data = await res.json();
      if (data?.error) message = data.error;
    } catch (_) {}
    throw new Error(message);
  }

  return res.json();
}

function getOperatorValue(incidentId) {
  const el = document.getElementById(`operator-input-${incidentId}`);
  return (el?.value || "").trim();
}

async function assignIncident(incidentId) {
  try {
    const assignedTo = getOperatorValue(incidentId) || "Robert";
    await postJson(`/api/incidents/${incidentId}/assign`, { assignedTo });
    await refreshAll();
  } catch (error) {
    console.error("assignIncident failed", error);
    alert(`Assign failed: ${error.message}`);
  }
}

async function acknowledgeIncident(incidentId) {
  try {
    const operator = getOperatorValue(incidentId) || "Robert";
    await postJson(`/api/incidents/${incidentId}/acknowledge`, {
      operator,
      note: "Acknowledged from UI"
    });
    await refreshAll();
  } catch (error) {
    console.error("acknowledgeIncident failed", error);
    alert(`Acknowledge failed: ${error.message}`);
  }
}

async function resolveIncident(incidentId) {
  try {
    const operator = getOperatorValue(incidentId) || "Robert";
    await postJson(`/api/incidents/${incidentId}/resolve`, {
      operator,
      resolution: "Resolved from UI"
    });
    await refreshAll();
  } catch (error) {
    console.error("resolveIncident failed", error);
    alert(`Resolve failed: ${error.message}`);
  }
}

(function injectOperatorStyles() {
  if (document.getElementById("sd-operator-styles")) return;

  const style = document.createElement("style");
  style.id = "sd-operator-styles";
  style.textContent = `
