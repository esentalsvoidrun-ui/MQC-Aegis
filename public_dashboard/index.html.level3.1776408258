<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SignalDesk — AI Decision Engine</title>
  <style>
    :root {
      --bg: #07111a;
      --panel: #0d1824;
      --panel-2: #122131;
      --line: rgba(255,255,255,0.08);
      --text: #edf3f8;
      --muted: #95a7b8;
      --danger: #ff5f6d;
      --warning: #ffb84d;
      --info: #57b8ff;
      --ok: #45d483;
      --shadow: 0 20px 60px rgba(0,0,0,0.35);
      --radius: 20px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, Arial, sans-serif;
      background:
        radial-gradient(circle at top left, rgba(87,184,255,0.12), transparent 30%),
        radial-gradient(circle at top right, rgba(255,95,109,0.08), transparent 30%),
        var(--bg);
      color: var(--text);
    }

    .wrap {
      max-width: 1480px;
      margin: 0 auto;
      padding: 28px;
    }

    .hero {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 24px;
    }

    .hero h1 {
      margin: 0 0 8px;
      font-size: 36px;
      line-height: 1.05;
    }

    .hero p {
      margin: 0;
      color: var(--muted);
      max-width: 760px;
      line-height: 1.5;
    }

    .pill {
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.03);
      color: var(--muted);
      padding: 10px 14px;
      border-radius: 999px;
      white-space: nowrap;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 20px;
    }

    .stack {
      display: grid;
      gap: 20px;
    }

    .panel {
      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 20px;
    }

    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 16px;
    }

    .eyebrow {
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.16em;
      margin-bottom: 6px;
    }

    .panel-header h2 {
      margin: 0;
      font-size: 24px;
    }

    .status-dot {
      width: 12px;
      height: 12px;
      border-radius: 999px;
      background: #64748b;
      box-shadow: 0 0 0 6px rgba(255,255,255,0.04);
    }

    .status-dot.live { background: var(--ok); }
    .status-dot.down { background: var(--danger); }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
      margin-bottom: 18px;
    }

    .stat-card {
      background: var(--panel-2);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 16px;
    }

    .stat-label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .stat-value {
      font-size: 30px;
      font-weight: 700;
    }

    .summary-copy p {
      margin: 0 0 10px;
      color: var(--text);
      line-height: 1.5;
    }

    .summary-copy .recommendation {
      color: var(--muted);
    }

    .case-list, .list-col {
      display: grid;
      gap: 16px;
    }

    .case-card, .list-card {
      background: var(--panel-2);
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 18px;
    }

    .case-top, .list-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
    }

    .case-id {
      color: var(--muted);
      font-size: 12px;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
      word-break: break-all;
    }

    .case-title, .list-title {
      font-size: 20px;
      font-weight: 700;
      line-height: 1.2;
    }

    .case-badges, .list-badges {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .badge {
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.04);
      color: var(--text);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .badge.danger {
      background: rgba(255,95,109,0.12);
      color: #ffd5d9;
      border-color: rgba(255,95,109,0.22);
    }

    .badge.warning {
      background: rgba(255,184,77,0.12);
      color: #ffe4b3;
      border-color: rgba(255,184,77,0.22);
    }

    .badge.info {
      background: rgba(87,184,255,0.12);
      color: #d2eeff;
      border-color: rgba(87,184,255,0.22);
    }

    .badge.muted {
      background: rgba(255,255,255,0.05);
      color: var(--muted);
    }

    .case-meta, .list-grid, .timeline-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px 16px;
    }

    .case-meta div, .list-grid div, .timeline-grid div {
      background: rgba(255,255,255,0.025);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 12px;
    }

    .case-meta span, .list-grid span, .timeline-grid span {
      display: block;
      color: var(--muted);
      font-size: 12px;
      margin-bottom: 6px;
    }

    .timeline {
      position: relative;
      display: grid;
      gap: 14px;
      margin-top: 16px;
    }

    .timeline-item {
      position: relative;
      padding-left: 28px;
    }

    .timeline-line {
      position: absolute;
      left: 8px;
      top: 18px;
      bottom: -20px;
      width: 2px;
      background: rgba(255,255,255,0.08);
    }

    .timeline-item:last-child .timeline-line {
      display: none;
    }

    .timeline-dot {
      position: absolute;
      left: 0;
      top: 10px;
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: #64748b;
      border: 3px solid var(--bg);
      box-shadow: 0 0 0 3px rgba(255,255,255,0.05);
    }

    .timeline-dot.critical { background: var(--danger); }
    .timeline-dot.high { background: var(--warning); }
    .timeline-dot.medium { background: var(--info); }
    .timeline-dot.low { background: var(--ok); }

    .timeline-body {
      background: rgba(255,255,255,0.025);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 14px;
    }

    .timeline-head {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      margin-bottom: 10px;
    }

    .timeline-title {
      font-size: 16px;
      font-weight: 700;
    }

    .timeline-time {
      font-size: 12px;
      color: var(--muted);
      white-space: nowrap;
    }

    .timeline-sub {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 12px;
    }

    .timeline-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 12px;
    }

    .mini-tag {
      font-size: 11px;
      border-radius: 999px;
      padding: 6px 9px;
      background: rgba(255,255,255,0.05);
      border: 1px solid var(--line);
      color: var(--muted);
      letter-spacing: 0.03em;
    }

    .empty-state {
      color: var(--muted);
      padding: 12px 2px;
    }

    @media (max-width: 1180px) {
      .grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .wrap {
        padding: 18px;
      }

      .hero {
        flex-direction: column;
      }

      .stats-grid,
      .case-meta,
      .list-grid,
      .timeline-grid {
        grid-template-columns: 1fr;
      }

      .timeline-head,
      .case-top,
      .list-head {
        flex-direction: column;
      }

      .case-badges,
      .list-badges {
        justify-content: flex-start;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <section class="hero">
      <div>
        <h1>SignalDesk — AI Decision Engine</h1>
        <p>
          Live analysis. Real-time signals. Multi-incident case flow.
          Not just alarms in a bucket — an actual chain of events with teeth.
        </p>
      </div>
      <div class="pill" id="connectionStatus">Live feed disconnected</div>
    </section>

    <div class="grid">
      <div class="stack">
        <section class="panel" id="summaryPanel"></section>
        <section class="panel" id="casePanel"></section>
      </div>

      <div class="stack">
        <section class="panel">
          <div class="panel-header">
            <div>
              <div class="eyebrow">INCIDENTS</div>
              <h2>Incident Stream</h2>
            </div>
          </div>
          <div class="list-col" id="incidentPanel"></div>
        </section>

        <section class="panel">
          <div class="panel-header">
            <div>
              <div class="eyebrow">ACTIONS</div>
              <h2>Operator Actions</h2>
            </div>
          </div>
          <div class="list-col" id="actionPanel"></div>
        </section>
      </div>
    </div>
  </div>

  <script src="./app.js"></script>
</body>
</html>
