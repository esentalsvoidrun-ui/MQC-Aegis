    }

    function renderDecisions() {
      const tbody = document.getElementById("decisionTableBody");
      const empty = document.getElementById("decisionEmpty");
      const decisions = getFilteredDecisions();

      if (!decisions.length) {
        tbody.innerHTML = "";
        empty.style.display = "block";
        return;
      }

      <style>
  .selected-case {
    outline: 2px solid rgba(90, 160, 255, 0.95);
    background: rgba(90, 160, 255, 0.08);
  }

  [data-case-id] {
    cursor: pointer;
  }
</style>

      tbody.innerHTML = decisions.map((d) => {
        const sla = getSlaState(d);
        const age = formatAge(getDecisionAgeMs(d));
        return `
          <tr data-id="${d.id}" class="${d.id === state.selectedDecisionId ? "active" : ""} ${sla.rowClass}">
            <td class="mono">#${d.id}</td>
            <td>${escapeHtml(d.user || "unknown")}</td>
            <td><span class="badge ${actionClass(d.recommendedAction)}">${escapeHtml(d.recommendedAction)}</span></td>
            <td><span class="badge ${statusClass(d.status)}">${escapeHtml(d.status)}</span></td>
            <td><span class="badge ${sla.className}">${escapeHtml(sla.label)} · ${escapeHtml(age)}</span></td>
            <td>${escapeHtml(d.riskScore)}</td>
            <td><span class="badge ${severityClass(d.severity)}">${escapeHtml(d.severity)}</span></td>
            <td>${escapeHtml(d.assignedTo || "—")}</td>
            <td>${escapeHtml(shortTime(d.createdAt))}</td>
          </tr>
        `;
      }).join("");

      [...tbody.querySelectorAll("tr")].forEach((row) => {
        row.addEventListener("click", () => selectDecision(Number(row.dataset.id)));
      });
    }

    function renderFeed(listId, rows, type) {
      const el = document.getElementById(listId);

      if (!rows.length) {
        el.innerHTML = `<div class="empty">No ${type} yet.</div>`;
        return;
      }

      el.innerHTML = rows.slice(0, 20).map((item) => {
        if (type === "incidents") {
          return `
            <div class="feed-item">
              <div class="feed-top">
                <div class="feed-title">${escapeHtml(item.type || "event")} · ${escapeHtml(item.user || "unknown")}</div>
                <div><span class="badge ${severityClass(item.severity)}">${escapeHtml(item.severity)}</span></div>
              </div>
              <div class="feed-meta">
                riskScore: ${escapeHtml(item.riskScore)} · action: ${escapeHtml(item.action)} · ip: ${escapeHtml(item.ip || "—")}<br>
                ${escapeHtml(fmtTime(item.timestamp))}
              </div>
            </div>
          `;
        }

        return `
          <div class="feed-item">
            <div class="feed-top">
              <div class="feed-title">${escapeHtml(item.action)}</div>
              <div class="feed-meta">${escapeHtml(item.time || "—")}</div>
            </div>
            <div class="feed-meta">
              ${escapeHtml(item.reason || "No reason")}<br>
              priority: ${escapeHtml(item.priority || "normal")} · source: ${escapeHtml(item.source || "system")}
            </div>
          </div>
        `;
      }).join("");
    }

    function renderHotFeed() {
      const el = document.getElementById("hotFeed");
      const hot = [...state.decisions]
        .sort((a, b) => {
          const slaA = getSlaState(a).label === "breach" ? 2 : getSlaState(a).label === "warn" ? 1 : 0;
          const slaB = getSlaState(b).label === "breach" ? 2 : getSlaState(b).label === "warn" ? 1 : 0;
          if (slaB !== slaA) return slaB - slaA;
          return (b.riskScore || 0) - (a.riskScore || 0);
        })
        .slice(0, 12);

      if (!hot.length) {
        el.innerHTML = `<div class="empty">No hot cases yet.</div>`;
        return;
      }

      el.innerHTML = hot.map((d) => {
        const sla = getSlaState(d);
        return `
          <div class="feed-item" style="cursor:pointer;" onclick="selectDecision(${d.id})">
            <div class="feed-top">
              <div class="feed-title mono">#${escapeHtml(d.id)} · ${escapeHtml(d.user || "unknown")}</div>
              <div><span class="badge ${sla.className}">${escapeHtml(sla.label)}</span></div>
            </div>
            <div class="feed-meta">
              action: ${escapeHtml(d.recommendedAction)} · status: ${escapeHtml(d.status)}<br>
              risk: ${escapeHtml(d.riskScore)} · age: ${escapeHtml(formatAge(getDecisionAgeMs(d)))}
            </div>
          </div>
        `;
      }).join("");
    }

    function renderCaseDetail(data) {
      const el = document.getElementById("caseDetail");

      if (!data || !data.decision) {
        el.innerHTML = `<div class="empty">No case selected. Pick one from the queue.</div>`;
        return;
      }

      const { decision, incident, timeline, enforcement } = data;
      const reasonCodes = Array.isArray(decision.reasonCodes) ? decision.reasonCodes : [];
      const noteValue = decision.note || "";
      const sla = getSlaState(decision);
      const ageText = formatAge(getDecisionAgeMs(decision));

      el.innerHTML = `
        <div class="detail-grid">
          <div class="detail-box">
            <div class="k">Decision</div>
            <div class="v mono">#${escapeHtml(decision.id)}</div>
          </div>
          <div class="detail-box">
            <div class="k">Incident</div>
            <div class="v mono">${incident?.id ? "#" + escapeHtml(incident.id) : "—"}</div>
          </div>
          <div class="detail-box">
            <div class="k">User</div>
            <div class="v">${escapeHtml(decision.user || "unknown")}</div>
          </div>
          <div class="detail-box">
            <div class="k">Recommended Action</div>
            <div class="v"><span class="badge ${actionClass(decision.recommendedAction)}">${escapeHtml(decision.recommendedAction)}</span></div>
          </div>
          <div class="detail-box">
            <div class="k">Status</div>
            <div class="v"><span class="badge ${statusClass(decision.status)}">${escapeHtml(decision.status)}</span></div>
          </div>
          <div class="detail-box">
            <div class="k">SLA / Age</div>
            <div class="v"><span class="badge ${sla.className}">${escapeHtml(sla.label)}</span> &nbsp; ${escapeHtml(ageText)}</div>
          </div>
          <div class="detail-box">
            <div class="k">Risk / Severity</div>
            <div class="v">${escapeHtml(decision.riskScore)} · <span class="badge ${severityClass(decision.severity)}">${escapeHtml(decision.severity)}</span></div>
          </div>
          <div class="detail-box">
            <div class="k">Assigned</div>
            <div class="v">${escapeHtml(decision.assignedTo || "—")}</div>
          </div>
        </div>

        <div class="detail-box" style="margin-bottom:16px;">
          <div class="k">Incident Context</div>
          <div class="v" style="font-size:14px;line-height:1.7;">
            type: ${escapeHtml(incident?.type || "—")}<br>
            ip: ${escapeHtml(incident?.ip || "—")}<br>
            amount: ${escapeHtml(incident?.amount ?? "—")}<br>
            correlation: ${escapeHtml(incident?.correlation?.reason || "none")}<br>
            trend anomaly: ${escapeHtml(incident?.trendAnomaly?.reason || "none")}<br>
            created: ${escapeHtml(fmtTime(decision.createdAt))}
          </div>
        </div>

        <div style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;">Reason Codes</div>
        <div class="reason-list">
          ${reasonCodes.length
            ? reasonCodes.map((code) => `<span class="chip">${escapeHtml(code)}</span>`).join("")
            : `<span class="chip">no_reason_codes</span>`
          }
        </div>

        <div class="actions-row">
          <button class="action-btn" data-action="approve">Approve</button>
<button class="action-btn" data-action="execute">Execute</button>
<button class="action-btn" data-action="reject">Reject</button>
<button class="action-btn" data-action="reverse">Reverse</button>
        </div>

        <div style="margin-bottom:16px;">
          <div style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;">Operator Note</div>
          <textarea id="caseNoteInput" placeholder="Write operator note...">${escapeHtml(noteValue)}</textarea>
          <div style="margin-top:10px;">
            <button class="btn primary" data-op="add-note">Add note</button>
          </div>
<style>
.selected-case {
  outline: 1px solid rgba(120, 180, 255, 0.9);
  box-shadow: 0 0 0 1px rgba(120, 180, 255, 0.25) inset;
}
</style>       
 </div>

        <div class="detail-box" style="margin-bottom:16px;">
          <div class="k">Enforcement</div>
          <div class="v" style="font-size:14px;line-height:1.7;">
            status: ${escapeHtml(enforcement?.status || "none")}<br>
            action: ${escapeHtml(enforcement?.action || "—")}<br>
            target: ${escapeHtml(enforcement?.targetId || "—")}<br>
            mode: ${escapeHtml(enforcement?.mode || "—")}<br>
            started: ${escapeHtml(fmtTime(enforcement?.startedAt))}<br>
            ended: ${escapeHtml(fmtTime(enforcement?.endedAt))}
          </div>
        </div>

        <div style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px;">Timeline</div>
        <div class="timeline">
          ${(timeline || []).length
            ? timeline.map((t) => `
                <div class="timeline-item">
                  <div class="timeline-top">
                    <strong>${escapeHtml(t.action)}</strong>
                    <span class="timeline-meta">${escapeHtml(fmtTime(t.timestamp))}</span>
                  </div>
                  <div class="timeline-meta">
                    actor: ${escapeHtml(t.actorType)} / ${escapeHtml(t.actorId)} · ${escapeHtml(t.fromStatus || "—")} → ${escapeHtml(t.toStatus || "—")}
                  </div>
                  <div class="timeline-note">${escapeHtml(t.note || "—")}</div>
                </div>
              `).join("")
            : `<div class="empty">No timeline entries yet.</div>`
          }
        </div>
      `;

      [...el.querySelectorAll("[data-op]")].forEach((btn) => {
        btn.addEventListener("click", () => handleDecisionOperation(btn.dataset.op, decision.id));
      });
    }

    async function api(url, options = {}) {
      const res = await fetch(url, {
        headers: { "Content-Type": "application/json" },
        ...options
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.error || "Request failed");
      return data;
    }

    async function loadInitialData() {
      const [incidents, actions, decisions, summary, operatorStats] = await Promise.all([
        api("/api/incidents"),
        api("/api/actions"),
        api("/api/decisions"),
        api("/api/summary"),
        api("/api/operator/stats")
      ]);

      state.incidents = incidents || [];
      state.actions = actions || [];
      state.decisions = decisions || [];
      state.summary = summary || null;
      state.operatorStats = operatorStats || null;

      if (!state.selectedDecisionId && state.decisions.length) {
        state.selectedDecisionId = state.decisions[0].id;
      }

      renderAll();

      if (state.selectedDecisionId) {
        await selectDecision(state.selectedDecisionId);
      }
    }

    async function selectDecision(id) {
      state.selectedDecisionId = id;
      renderDecisions();

      const data = await api(`/api/decisions/${id}`);
      state.currentCase = data;
      renderCaseDetail(data);
    }

    async function handleDecisionOperation(op, decisionId) {
      try {
        if (!decisionId) return;

        if (op === "refresh-case") {
          await selectDecision(decisionId);
          await refreshSummaryAndStats();
          return;
        }

        const currentNote = document.getElementById("caseNoteInput")?.value?.trim() || "";
        let payload = { operatorId: "robert" };
        let url = "";

        if (op === "approve") {
          url = `/api/decisions/${decisionId}/approve`;
          payload.note = currentNote || "Approved by operator";
        } else if (op === "reject") {
          url = `/api/decisions/${decisionId}/reject`;
          payload.note = currentNote || "Rejected by operator";
        } else if (op === "execute") {
          url = `/api/decisions/${decisionId}/execute`;
          payload.note = currentNote || "Executed in simulated mode";
        } else if (op === "reverse") {
          url = `/api/decisions/${decisionId}/reverse`;
          payload.note = currentNote || "Reversed by operator";
        } else if (op === "assign") {
          url = `/api/decisions/${decisionId}/assign`;
          payload.assignedTo = "robert";
          payload.note = currentNote || "Assigned to robert";
        } else if (op === "add-note") {
          url = `/api/decisions/${decisionId}/note`;
          payload.note = currentNote || "Operator note added";
        }

        await api(url, {
          method: "POST",
          body: JSON.stringify(payload)
        });

        await Promise.all([refreshDecisions(), refreshSummaryAndStats()]);
        await selectDecision(decisionId);
      } catch (error) {
        alert(error.message);
      }
    }

    async function refreshDecisions() {
      const status = document.getElementById("statusFilter").value;
      const action = document.getElementById("actionFilter").value;

      const qs = new URLSearchParams();
      if (status) qs.set("status", status);
      if (action) qs.set("action", action);

      state.decisions = await api(`/api/decisions${qs.toString() ? "?" + qs.toString() : ""}`);
      renderDecisions();
      renderHotFeed();
      renderStatsBand(state.summary, state.operatorStats);
    }

    async function refreshSummaryAndStats() {
      const [summary, operatorStats] = await Promise.all([
        api("/api/summary"),
        api("/api/operator/stats")
      ]);

      state.summary = summary;
      state.operatorStats = operatorStats;
      renderHero(state.summary, state.operatorStats);
      renderStatsBand(state.summary, state.operatorStats);
    }

    function renderAll() {
      renderHero(state.summary, state.operatorStats);
      renderStatsBand(state.summary, state.operatorStats);
      renderDecisions();
      renderFeed("incidentFeed", state.incidents, "incidents");
      renderFeed("actionFeed", state.actions, "actions");
      renderHotFeed();
      renderCaseDetail(state.currentCase);
    }

    function upsertById(arr, item) {
      const idx = arr.findIndex((x) => x.id === item.id);
      if (idx === -1) arr.unshift(item);
      else arr[idx] = item;
    }

    function setupWs() {
      const protocol = location.protocol === "https:" ? "wss" : "ws";
      const ws = new WebSocket(`${protocol}://${location.host}`);
      const wsStatus = document.getElementById("wsStatus");

      ws.addEventListener("open", () => {
        wsStatus.textContent = "Live engine connected";
      });

      ws.addEventListener("close", () => {
        wsStatus.textContent = "Link lost";
      });

      ws.addEventListener("message", async (event) => {
        try {
          const msg = JSON.parse(event.data);

          if (msg.type === "bootstrap") {
            state.incidents = msg.payload.incidents || [];
            state.actions = msg.payload.actions || [];
            state.decisions = msg.payload.decisions || [];
            state.summary = msg.payload.summary || null;

            renderAll();

            if (!state.selectedDecisionId && state.decisions.length) {
              state.selectedDecisionId = state.decisions[0].id;
            }

            if (state.selectedDecisionId) {
              await selectDecision(state.selectedDecisionId);
            }

            await refreshSummaryAndStats();
            return;
          }

          if (msg.type === "incident") {
            upsertById(state.incidents, msg.payload);
            renderFeed("incidentFeed", state.incidents, "incidents");
            await refreshSummaryAndStats();
            return;
          }

          if (msg.type === "action") {
            upsertById(state.actions, msg.payload);
            renderFeed("actionFeed", state.actions, "actions");
            return;
          }

          if (msg.type === "decision" || msg.type === "decision_update") {
            upsertById(state.decisions, msg.payload);
            renderDecisions();
            renderHotFeed();
            renderStatsBand(state.summary, state.operatorStats);
            await refreshSummaryAndStats();

            if (state.selectedDecisionId === msg.payload.id) {
              await selectDecision(msg.payload.id);
            }
            return;
          }

          if (msg.type === "summary") {
            state.summary = msg.payload;
            renderHero(state.summary, state.operatorStats);
            renderStatsBand(state.summary, state.operatorStats);
            return;
          }

          if (msg.type === "decision_timeline" || msg.type === "enforcement") {
            if (state.selectedDecisionId) {
              await selectDecision(state.selectedDecisionId);
            }
            await refreshSummaryAndStats();
          }
        } catch (err) {
          console.error("WS parse error", err);
        }
      });
    }

    document.getElementById("refreshBtn").addEventListener("click", async () => {
      await Promise.all([refreshDecisions(), refreshSummaryAndStats()]);
      if (state.selectedDecisionId) {
        await selectDecision(state.selectedDecisionId);
      }
    });

    document.getElementById("statusFilter").addEventListener("change", refreshDecisions);
    document.getElementById("actionFilter").addEventListener("change", refreshDecisions);

    setInterval(() => {
      renderDecisions();
      renderHotFeed();
      renderStatsBand(state.summary, state.operatorStats);
      if (state.currentCase?.decision?.id === state.selectedDecisionId) {
        renderCaseDetail(state.currentCase);
      }
    }, 15000);

    loadInitialData().catch((err) => {
      console.error(err);
      alert("Failed to load dashboard: " + err.message);
    });

    setupWs();

    window.selectDecision = selectDecision;
  </script>
</body>
