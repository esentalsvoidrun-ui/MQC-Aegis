let token = localStorage.getItem("token") || "";

function setStatus(text) {
  const aiEl = document.getElementById("aiInsight");
  if (el) el.textContent = text;
}

async function registerUser() {
  setStatus("Registering...");

  const email = document.getElementById("email").value;
  const password = document.getElementById("password").value;

  try {
    const res = await fetch("/api/register", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({ email, password })
    });

    const data = await res.json();
    if (!res.ok) throw new Error(data.error || "Register failed");

    setStatus("Registered. You can now login.");
  } catch (err) {
    setStatus("Register error: " + err.message);
  }
}

async function loginUser() {
  setStatus("Logging in...");

  const email = document.getElementById("email").value;
  const password = document.getElementById("password").value;

  try {
    const res = await fetch("/api/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email, password })
    });

    const data = await res.json();
    if (!res.ok) throw new Error(data.error || "Login failed");

    token = data.token;
    localStorage.setItem("token", token);
    setStatus("Logged in");
    await loadInsights();
  } catch (err) {
    setStatus("Login error: " + err.message);
  }
}

async function loadInsights() {
  const insightEl = document.getElementById("insight");
  const riskEl = document.getElementById("risk");
  const actionEl = document.getElementById("action");
  const confidenceEl = document.getElementById("confidence");
  const signalsEl = document.getElementById("signals");
  const humanLayerEl = document.getElementById("humanLayer");
  const btn = document.getElementById("analyzeBtn");
const aiEl = document.getElementById("aiInsight");
aiEl.textContent = data.aiInsight || "";
  if (!token) {
    insightEl.textContent = "Login required";
    riskEl.textContent = "-";
    actionEl.textContent = "Please register or log in.";
    confidenceEl.textContent = "-";
    signalsEl.textContent = "-";
    humanLayerEl.textContent = "-";
    riskEl.className = "";
aiEl.textContent = data.aiInsight || "";
    return;
  }

  btn.textContent = "Analyzing...";
  insightEl.textContent = "Loading...";
  riskEl.textContent = "-";
  actionEl.textContent = "-";
  confidenceEl.textContent = "-";
  signalsEl.textContent = "-";
  humanLayerEl.textContent = "-";
  riskEl.className = "";

  try {
    const res = await fetch("/analyze", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": token
      },
      body: JSON.stringify({
        users: Number(document.getElementById("users").value),
        revenue: Number(document.getElementById("revenue").value),
        sessions: Number(document.getElementById("sessions").value),
        churn: Number(document.getElementById("churn").value)
      })
    });

    const data = await res.json();
    if (!res.ok) throw new Error(data.error || "Failed to load insights");

    insightEl.textContent = data.insight || "No insight";
    riskEl.textContent = data.risk || "No risk";
    actionEl.textContent = data.action || "No action";
    confidenceEl.textContent =
      typeof data.confidence === "number" ? data.confidence + "%" : "-";

        if (Array.isArray(data.signals) && data.signals.length > 0) {
      signalsEl.textContent = data.signals.join(" • ");
    } else if (Array.isArray(data.warnings) && data.warnings.length > 0) {
      signalsEl.textContent = data.warnings.join(" • ");
    } else if (Array.isArray(data.positives) && data.positives.length > 0) {
      signalsEl.textContent = data.positives.join(" • ");
    } else {
      signalsEl.textContent = "No major signals detected";
    }

    if (data.risk === "LOW") riskEl.className = "risk-low";
    if (data.risk === "MEDIUM") riskEl.className = "risk-medium";
    if (data.risk === "HIGH") riskEl.className = "risk-high";

    const humanBits = [];
    if (Array.isArray(data.positives) && data.positives.length) {
      humanBits.push("Strengths: " + data.positives.join(", "));
    }
    if (Array.isArray(data.warnings) && data.warnings.length) {
      humanBits.push("Warnings: " + data.warnings.join(", "));
    }

    humanLayerEl.textContent = humanBits.length
      ? humanBits.join(" | ")
      : "Small early signals are often the ones worth respecting.";
  } catch (err) {
    insightEl.textContent = "Failed to load AI insights";
    riskEl.textContent = "ERROR";
    actionEl.textContent = err.message;
    confidenceEl.textContent = "-";
    signalsEl.textContent = "-";
    humanLayerEl.textContent = "Kontrollen tappades, men inte bygget.";
    riskEl.className = "risk-high";
  } finally {
    btn.textContent = "Analyze";
  }
}

window.registerUser = registerUser;
window.loginUser = loginUser;
window.loadInsights = loadInsights;

