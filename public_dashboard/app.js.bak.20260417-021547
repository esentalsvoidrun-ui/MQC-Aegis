let selectedCaseId = null;

async function postCaseAction(action) {
  if (!selectedCaseId) {
    alert("Select a case first");
    return;
  }

  try {
    const res = await fetch(`/api/cases/${selectedCaseId}/action`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        action,
        operator: "robert"
      })
    });

    const data = await res.json();

    if (!data.ok) {
      throw new Error(data.error || "Action failed");
    }

    console.log("Case action updated:", data);
  } catch (err) {
    console.error(err);
    alert("Action failed: " + err.message);
  }
}

function wireCaseActionButtons() {
  document.querySelectorAll(".action-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const action = btn.dataset.action;
      postCaseAction(action);
    });
  });
}

function wireQueueSelection() {
  document.querySelectorAll("[data-case-id]").forEach((row) => {
    row.addEventListener("click", () => {
      selectedCaseId = row.dataset.caseId;
      console.log("Selected case:", selectedCaseId);

      document.querySelectorAll("[data-case-id]").forEach((el) => {
        el.classList.remove("selected-case");
      });

      row.classList.add("selected-case");
    });
  });
}

function patchWsCaseUpdates() {
  const OriginalWebSocket = window.WebSocket;

  window.WebSocket = function (...args) {
    const socket = new OriginalWebSocket(...args);

    socket.addEventListener("message", (event) => {
      try {
        const msg = JSON.parse(event.data);

        if (msg.type === "case_updated") {
          console.log("Live case update:", msg.data);
          setTimeout(() => window.location.reload(), 300);
        }

        if (msg.type === "actions_updated") {
          console.log("Live actions update");
        }

        if (msg.type === "incidents_updated") {
          console.log("Live incidents update");
        }
      } catch (e) {
        console.error("WS parse error", e);
      }
    });

    return socket;
  };

  window.WebSocket.prototype = OriginalWebSocket.prototype;
}

document.addEventListener("DOMContentLoaded", () => {
  patchWsCaseUpdates();
  wireCaseActionButtons();
  wireQueueSelection();
});

