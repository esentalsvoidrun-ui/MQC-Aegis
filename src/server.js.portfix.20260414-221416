// SIGNALDESK_AI_INSIGHT_ROUTE
app.get("/api/ai-insight", async (req, res) => {
  try {
    const context = {
      users: Math.floor(900 + Math.random() * 900),
      revenue: Math.floor(20000 + Math.random() * 50000),
      risk: Math.floor(8 + Math.random() * 55),
      sessions: Math.floor(20 + Math.random() * 180),
      timestamp: Date.now()
    };

    const fallbackInsight = (() => {
      const revenueTone =
        context.revenue > 50000
          ? "Revenue is running strongly above baseline."
          : "Revenue is active but still has room to accelerate.";

      const riskTone =
        context.risk < 20
          ? "Risk remains contained."
          : context.risk < 40
          ? "Risk is elevated but manageable."
          : "Risk conditions are rising and should be monitored closely.";

      const userTone =
        context.users > 1400
          ? "User activity is unusually strong."
          : "User activity is stable and healthy.";

      return `${userTone} ${revenueTone} ${riskTone} Recommendation: continue monitoring anomaly density while preserving current decision flow.`;
    })();

    if (process.env.OPENAI_API_KEY) {
      try {
        const OpenAI = (await import("openai")).default;
        const client = new OpenAI({ apiKey: process.env.OPENAI_API_KEY });

        const response = await client.chat.completions.create({
          model: process.env.OPENAI_MODEL || "gpt-4o-mini",
          temperature: 0.7,
          max_tokens: 140,
          messages: [
            {
              role: "system",
              content:
                "You are the AI analyst inside SignalDesk, an enterprise decision engine dashboard. Return one concise, sharp executive insight in plain English. Sound premium, confident, and product-grade. No bullets. No markdown."
            },
            {
              role: "user",
              content:
                `Analyze this dashboard snapshot and give one strong operational insight with a recommendation. Data: users=${context.users}, revenue=${context.revenue}, risk=${context.risk}, sessions=${context.sessions}.`
            }
          ]
        });

        const insight =
          response?.choices?.[0]?.message?.content?.trim() || fallbackInsight;

        return res.json({
          ok: true,
          source: "openai",
          insight,
          context,
          timestamp: Date.now()
        });
      } catch (aiError) {
        console.error("AI insight generation failed, using fallback:", aiError.message);
      }
    }

    return res.json({
      ok: true,
      source: "fallback",
      insight: fallbackInsight,
      context,
      timestamp: Date.now()
    });
  } catch (error) {
    console.error("AI insight route error:", error);
    return res.status(500).json({
      ok: false,
      insight: "SignalDesk could not generate an insight right now.",
      error: error.message
    });
  }
});

